<%- include('../partials/head', { pageTitle: 'Submissions — ' + form.name }) %>
<%- include('../partials/nav') %>
<div class="main-content">
<%- include('../partials/topbar', { topTitle: form.name + ' — Submissions', topSub: 'All responses captured for this form.' }) %>
<main class="p-6">

<div class="mb-3 flex gap-2">
  <a href="/admin/forms" class="btn btn-ghost">← Forms</a>
  <a href="/admin/forms/<%= form.id %>" class="btn btn-secondary">Edit form</a>
</div>

<% if (!submissions.length) { %>
  <div class="card"><div class="card-body text-sm text-slate-500">No submissions yet.</div></div>
<% } %>

<div class="space-y-3">
  <% submissions.forEach(s => { let data = {}; try { data = JSON.parse(s.data_json); } catch(e){} %>
    <div class="card">
      <div class="card-body">
        <div class="flex items-center gap-2 mb-2">
          <span class="chip bg-slate-100 text-slate-700">#<%= s.id %></span>
          <span class="text-xs text-slate-500"><%= s.submitted_at %></span>
          <% if (s.submitted_by_name) { %><span class="text-xs text-slate-500">· <%= s.submitted_by_name %></span><% } %>
        </div>
        <table class="data text-sm">
          <tbody>
            <% Object.keys(data).forEach(k => { %>
              <tr><td class="font-medium w-1/3"><%= k %></td><td><%= data[k] %></td></tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  <% }) %>
</div>

</main></div>
</body></html>
