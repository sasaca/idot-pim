<% if (currentUser) { %>
<header class="bg-white border-b sticky top-0 z-10">
  <div class="flex items-center gap-4 px-6 py-3">
    <div class="flex-1">
      <h1 class="text-lg font-semibold"><%= typeof topTitle !== 'undefined' ? topTitle : '' %></h1>
      <% if (typeof topSub !== 'undefined' && topSub) { %><p class="text-xs text-slate-500"><%= topSub %></p><% } %>
    </div>
    <form action="/requests" method="get" class="hidden md:block">
      <input name="q" placeholder="Search requests…" class="px-3 py-1.5 border rounded-md text-sm w-64 focus:outline-none focus:ring-2 focus:ring-brand-500">
    </form>
    <a href="/dashboard" class="relative text-slate-600 hover:text-slate-900">
      <span>Notifications</span>
      <% if (unreadCount > 0) { %><span class="absolute -top-1 -right-3 bg-red-500 text-white text-[10px] px-1.5 rounded-full"><%= unreadCount %></span><% } %>
    </a>
  </div>
</header>
<% } %>
