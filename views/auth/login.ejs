<%- include('../partials/head', { pageTitle: 'Sign in — iDOT PIM' }) %>
<main class="min-h-screen grid place-items-center p-6 bg-gradient-to-br from-slate-900 via-slate-800 to-brand-900">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <div class="inline-flex w-14 h-14 rounded-xl bg-gradient-to-br from-brand-500 to-brand-700 text-white font-bold text-2xl items-center justify-center shadow-xl">i</div>
      <h1 class="text-2xl font-bold text-white mt-4">iDOT Product Information Management</h1>
      <p class="text-slate-400 mt-1 text-sm">Master Data. One platform. Every domain.</p>
    </div>
    <div class="bg-white rounded-xl shadow-2xl p-8">
      <h2 class="font-semibold text-lg mb-1">Sign in</h2>
      <p class="text-slate-500 text-sm mb-5">Demo mode — choose any account below to explore the product.</p>
      <% if (error) { %><div class="bg-red-50 border border-red-200 text-red-700 text-sm p-3 rounded mb-4"><%= error %></div><% } %>
      <form method="post" action="/login" class="space-y-3">
        <label class="field">
          <span class="label">Account</span>
          <select name="email" class="input" required>
            <% const groups = {}; users.forEach(u => { (groups[u.role] = groups[u.role] || []).push(u); }); %>
            <% for (const role in groups) { %>
              <optgroup label="<%= role.replace(/_/g,' ') %>">
                <% groups[role].forEach(u => { %>
                  <option value="<%= u.email %>"><%= u.name %> — <%= u.email %></option>
                <% }) %>
              </optgroup>
            <% } %>
          </select>
        </label>
        <button class="btn btn-primary w-full justify-center py-2.5">Sign in →</button>
      </form>
      <div class="text-xs text-slate-400 mt-4 text-center">Password not required in demo. SSO/SAML supported in production.</div>
    </div>
    <div class="text-center text-slate-500 text-xs mt-6">© iDOT PIM · SOC 2 Ready · GDPR Compliant</div>
  </div>
</main>
</body></html>
