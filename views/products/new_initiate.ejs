<%- include('../partials/head', { pageTitle: 'New Product Request — Initiate' }) %>
<%- include('../partials/nav') %>
<div class="main-content">
<%- include('../partials/topbar', { topTitle: 'New Product Request', topSub: 'Stage 1 — initiate the request' }) %>

<style>
  .pwf-card     { background:white; border:1px solid #e5e7eb; border-radius:.5rem; padding:1.25rem; box-shadow:0 1px 2px rgba(0,0,0,.05); margin-bottom:1rem; }
  .pwf-card h2  { font-size:1.05rem; font-weight:600; color:#111827; margin-bottom:.75rem; }
  .pwf-grid     { display:grid; grid-template-columns:repeat(2, minmax(0, 1fr)); gap:.9rem 1rem; }
  .pwf-field    { display:flex; flex-direction:column; gap:.25rem; }
  .pwf-field.full { grid-column:1 / -1; }
  .pwf-field label { font-size:.78rem; font-weight:500; color:#374151; }
  .pwf-field input, .pwf-field select, .pwf-field textarea {
    padding:.5rem .65rem; border:1px solid #d1d5db; border-radius:.35rem; font-size:.9rem; background:white;
  }
  .pwf-req      { color:#b91c1c; margin-right:.2rem; }
  .pwf-radio    { display:flex; gap:1rem; flex-wrap:wrap; padding-top:.25rem; }
  .pwf-radio label { font-size:.85rem; color:#1f2937; display:inline-flex; align-items:center; gap:.35rem; }
  .pwf-search-wrap { position:relative; }
  .pwf-search-results {
    position:absolute; left:0; right:0; top:calc(100% + 4px);
    background:white; border:1px solid #d1d5db; border-radius:.4rem; max-height:18rem;
    overflow-y:auto; z-index:30; box-shadow:0 4px 14px rgba(0,0,0,.08); display:none;
  }
  .pwf-search-results.open { display:block; }
  .pwf-search-row { padding:.5rem .65rem; border-bottom:1px solid #f3f4f6; cursor:pointer; font-size:.85rem; }
  .pwf-search-row:hover { background:#f9fafb; }
  .pwf-search-row .sku { font-family:ui-monospace,monospace; font-size:.75rem; color:#6b7280; }
  .pwf-pill { display:inline-block; padding:.1rem .45rem; border-radius:9999px; background:#eef2ff; color:#3730a3; font-size:.7rem; margin-left:.4rem; }
  .pwf-footer   { display:flex; justify-content:flex-end; gap:.5rem; padding:1rem 0; }
  .btn-primary  { background:#1d4ed8; color:white; border:none; padding:.55rem 1rem; border-radius:.35rem; font-size:.85rem; cursor:pointer; }
  .btn-primary:hover { background:#1e40af; }
  .btn-default  { background:white; color:#1f2937; border:1px solid #d1d5db; padding:.55rem 1rem; border-radius:.35rem; font-size:.85rem; cursor:pointer; }
</style>

<style>
  /* Multi-field SAP search panel */
  .ms-grid {
    display:grid; grid-template-columns: repeat(2, minmax(0,1fr)); gap:.75rem 1rem;
  }
  @media (min-width: 920px) { .ms-grid { grid-template-columns: repeat(5, minmax(0,1fr)); } }
  .ms-grid label { display:flex; flex-direction:column; gap:3px; font-size:11px; text-transform:uppercase; letter-spacing:.05em; color:#475569; font-weight:600; }
  .ms-grid input, .ms-grid select { padding:7px 10px; font-size:13px; border:1px solid #cbd5e1; border-radius:6px; background:white; }
  .ms-actions { display:flex; gap:8px; margin-top:.85rem; align-items:center; }
  .ms-table { width:100%; border-collapse:collapse; font-size:12.5px; margin-top:1rem; border:1px solid #e5e7eb; border-radius:8px; overflow:hidden; }
  .ms-table thead th { background:#f8fafc; padding:8px 10px; text-align:left; font-size:10.5px; font-weight:700; text-transform:uppercase; letter-spacing:.04em; color:#475569; border-bottom:1px solid #e5e7eb; white-space:nowrap; }
  .ms-table tbody td { padding:8px 10px; border-top:1px solid #f1f5f9; vertical-align:top; }
  .ms-table tbody tr { cursor:pointer; }
  .ms-table tbody tr:hover { background:#f8fafc; }
  .ms-table tbody tr.selected { background:#dbeafe; }
  .ms-table tbody tr.selected td { font-weight:500; color:#1e3a8a; }
  .ms-mat { font-family:ui-monospace,monospace; font-size:11px; color:#1e3a8a; }
  .ms-pill { display:inline-block; padding:1px 7px; border-radius:9999px; background:#eef2ff; color:#3730a3; font-size:10.5px; font-weight:600; letter-spacing:.02em; }
  .ms-pill.fert { background:#dcfce7; color:#166534; }
  .ms-meta { font-size:11px; color:#64748b; margin-top:.5rem; }
  .ms-banner {
    background:#eff6ff; border:1px solid #bfdbfe; border-radius:8px;
    padding:.65rem .9rem; font-size:13px; color:#1e3a8a; margin-top:.75rem;
    display:flex; align-items:center; gap:.6rem; flex-wrap:wrap;
  }
  .ms-banner strong { color:#1e40af; }
  .ms-clear-link { color:#1d4ed8; text-decoration:underline; cursor:pointer; }
  .ms-page-info { font-size: 12px; color: #475569; }
  .ms-page-buttons { display: inline-flex; gap: 4px; }
  .ms-page-buttons button {
    background: white; border: 1px solid #cbd5e1; padding: 4px 10px;
    font-size: 12px; border-radius: 5px; cursor: pointer; color: #475569;
    min-width: 32px;
  }
  .ms-page-buttons button:hover:not(:disabled) { background: #f1f5f9; }
  .ms-page-buttons button.active { background: #1e3a8a; color: white; border-color: #1e3a8a; font-weight: 600; }
  .ms-page-buttons button:disabled { opacity: .4; cursor: not-allowed; }
</style>

<main class="mx-auto max-w-6xl px-4 py-8">
  <form method="post" action="/products/workflow/new">
    <div class="pwf-card">
      <h2>1 · Type of request</h2>
      <div class="pwf-radio">
        <label><input type="radio" name="request_type" value="NEW_PRODUCT" required>New Product</label>
        <label><input type="radio" name="request_type" value="NEW_VARIATION">New Product Variation</label>
        <label><input type="radio" name="request_type" value="MODIFICATION">Product Modification</label>
        <label><input type="radio" name="request_type" value="DISCONTINUATION">Product Discontinuation</label>
      </div>
    </div>

    <div class="pwf-card">
      <h2>2 · Reference an existing finished good (optional)</h2>
      <p class="text-sm text-gray-600 mb-2">
        Search the SAP material master to find a similar finished good and reuse its
        BOM, dimensions and classification. Search by any single field or combine
        multiple — only Finished Goods (material type FERT) are returned.
      </p>

      <div class="ms-grid">
        <label>
          Material number
          <input id="ms-mat-num" type="text" autocomplete="off" placeholder="e.g. GCH-ORIG-150">
        </label>
        <label>
          Material description
          <input id="ms-mat-desc" type="text" autocomplete="off" placeholder="Type product name, brand…">
        </label>
        <label>
          Category
          <select id="ms-cat">
            <option value="">All categories</option>
            <% ref.CATEGORY_OPTIONS.forEach(function (g) { %>
              <optgroup label="<%= g.group %>">
                <option value="<%= g.group %>"><%= g.group %> — all</option>
                <% g.options.forEach(function (o) { %>
                  <option value="<%= o %>"><%= o %></option>
                <% }); %>
              </optgroup>
            <% }); %>
          </select>
        </label>
        <label>
          Brand
          <select id="ms-brand">
            <option value="">All brands</option>
            <% ref.BRAND_OPTIONS.forEach(function (g) { %>
              <optgroup label="<%= g.group %>">
                <option value="<%= g.group %>"><%= g.group %> — all</option>
                <% g.options.forEach(function (o) { %>
                  <option value="<%= o %>"><%= o %></option>
                <% }); %>
              </optgroup>
            <% }); %>
          </select>
        </label>
        <label>
          Material type
          <select id="ms-type">
            <option value="FERT" selected>FERT — Finished Good</option>
          </select>
        </label>
      </div>

      <div class="ms-actions">
        <button type="button" id="ms-search" class="btn-primary">🔎 Search</button>
        <button type="button" id="ms-reset"  class="btn-default">Clear</button>
        <span id="ms-status" class="ms-meta" style="margin-top:0;"></span>
      </div>

      <div id="ms-empty" class="ms-meta" style="margin-top:1rem; padding:1.25rem; border:1px dashed #cbd5e1; border-radius:8px; text-align:center; color:#64748b;">
        Type into any field above (or pick a Category / Brand) to search the Finished Goods catalog. Designed to scale to thousands of SKUs — results paginate 15 at a time.
      </div>

      <div id="ms-results-wrap" style="display:none;">
        <table class="ms-table" id="ms-table">
          <thead>
            <tr>
              <th>Material #</th>
              <th>Description</th>
              <th>Category</th>
              <th>Brand</th>
              <th>Material group</th>
              <th>Type</th>
              <th>Div.</th>
              <th>UoM</th>
              <th>Origin</th>
            </tr>
          </thead>
          <tbody id="ms-results"></tbody>
        </table>
        <div id="ms-pagination" class="ms-pagination" style="display:flex; align-items:center; justify-content:space-between; gap:.6rem; margin-top:.6rem; flex-wrap:wrap;"></div>
      </div>

      <input id="reference_sku" type="hidden" name="reference_sku">
      <div id="ms-selected" class="ms-banner" style="display:none;"></div>
    </div>

    <div class="pwf-card">
      <h2>3 · Project details</h2>
      <div class="pwf-grid">
        <div class="pwf-field">
          <label><span class="pwf-req">*</span>Request date</label>
          <input type="date" name="request_date" required value="<%= new Date().toISOString().slice(0,10) %>">
        </div>
        <div class="pwf-field">
          <label>Requestor</label>
          <input type="text" value="<%= currentUser ? (currentUser.name + ' (' + currentUser.email + ')') : '' %>" readonly
                 style="background:#f3f4f6; color:#374151;">
        </div>
        <div class="pwf-field full">
          <label><span class="pwf-req">*</span>Product name</label>
          <input type="text" name="product_name" required placeholder="e.g. GoldenChips Lime &amp; Chilli 150g">
        </div>
      </div>
    </div>

    <div class="pwf-footer">
      <a href="/products" class="btn-default">Cancel</a>
      <button type="submit" class="btn-primary">Continue to details →</button>
    </div>
  </form>
</main>

<script>
(function () {
  // SAP-style multi-field finished-good search.
  var inputs = {
    material_number:      document.getElementById('ms-mat-num'),
    material_description: document.getElementById('ms-mat-desc'),
    category:             document.getElementById('ms-cat'),
    brand:                document.getElementById('ms-brand'),
    material_type:        document.getElementById('ms-type'),
  };
  var status      = document.getElementById('ms-status');
  var resultsWrap = document.getElementById('ms-results-wrap');
  var resultsBody = document.getElementById('ms-results');
  var emptyState  = document.getElementById('ms-empty');
  var pagination  = document.getElementById('ms-pagination');
  var skuInput    = document.getElementById('reference_sku');
  var selected    = document.getElementById('ms-selected');
  var currentPage = 1;

  // Submit on enter from any input.
  Object.values(inputs).forEach(function (el) {
    el.addEventListener('keydown', function (e) { if (e.key === 'Enter') { e.preventDefault(); runSearch(); } });
  });

  document.getElementById('ms-search').addEventListener('click', function () { currentPage = 1; runSearch(); });
  document.getElementById('ms-reset').addEventListener('click', function () {
    Object.keys(inputs).forEach(function (k) {
      if (k === 'material_type') inputs[k].value = 'FERT';
      else inputs[k].value = '';
    });
    clearSelection();
    currentPage = 1;
    showEmpty();        // back to the "type to search" placeholder
  });

  // Live search — fires 150ms after the user stops typing in any text field,
  // immediately on a dropdown change. Resets to page 1 whenever filters
  // change.
  var debounce = null;
  Object.values(inputs).forEach(function (el) {
    if (el.tagName === 'SELECT') {
      el.addEventListener('change', function () { currentPage = 1; runSearch(); });
    } else {
      el.addEventListener('input', function () {
        clearTimeout(debounce);
        debounce = setTimeout(function () { currentPage = 1; runSearch(); }, 150);
      });
    }
  });

  function showEmpty() {
    emptyState.style.display = '';
    resultsWrap.style.display = 'none';
    resultsBody.innerHTML = '';
    pagination.innerHTML = '';
    status.textContent = '';
  }

  async function runSearch() {
    var params = new URLSearchParams();
    Object.keys(inputs).forEach(function (k) {
      var v = (inputs[k].value || '').trim();
      if (v) params.append(k, v);
    });
    params.set('page', String(currentPage));
    status.textContent = 'Searching…'; status.style.color = '#475569';
    try {
      var resp = await fetch('/products/workflow/api/reference-search?' + params.toString());
      var data = await resp.json();
      if (!data.filtered) { showEmpty(); return; }
      emptyState.style.display = 'none';
      render(data);
    } catch (e) {
      console.error(e);
      status.textContent = '⚠ Search failed.'; status.style.color = '#b91c1c';
    }
  }

  function render(data) {
    resultsWrap.style.display = '';
    var rows  = data.results || [];
    var total = data.total || 0;
    var page  = data.page || 1;
    var pages = data.totalPages || 0;
    var size  = data.pageSize || 15;

    if (!rows.length) {
      resultsBody.innerHTML = '<tr><td colspan="9" style="padding:18px; text-align:center; color:#94a3b8;">No matching finished goods.</td></tr>';
      pagination.innerHTML = '';
      status.textContent = '0 results.'; status.style.color = '#475569';
      return;
    }
    var first = (page - 1) * size + 1;
    var last  = Math.min(page * size, total);
    status.innerHTML = '<strong>' + total + ' result' + (total === 1 ? '' : 's') + '</strong> · showing ' + first + '–' + last;
    status.style.color = '#065f46';

    resultsBody.innerHTML = rows.map(function (r) {
      var brand = [r.brand, r.sub_brand].filter(Boolean).join(' / ');
      return '<tr data-sku="' + escAttr(r.sku) + '" data-name="' + escAttr(r.name) + '">' +
        '<td><span class="ms-mat">' + escHtml(r.sku) + '</span></td>' +
        '<td><strong>' + escHtml(r.name) + '</strong></td>' +
        '<td>' + escHtml(r.category || '—') + '<div style="font-size:11px;color:#94a3b8;">' + escHtml(r.category_grouper || '') + '</div></td>' +
        '<td>' + escHtml(brand || '—') + '</td>' +
        '<td><span class="ms-pill">' + escHtml(r.material_group || '') + '</span></td>' +
        '<td><span class="ms-pill fert">' + escHtml(r.material_type || 'FERT') + '</span></td>' +
        '<td>' + escHtml(r.division || '') + '</td>' +
        '<td>' + escHtml(r.base_uom || '') + '</td>' +
        '<td>' + escHtml(r.country_of_origin || '') + '</td>' +
        '</tr>';
    }).join('');
    Array.from(resultsBody.querySelectorAll('tr[data-sku]')).forEach(function (row) {
      row.addEventListener('click', function () { pick(row.dataset.sku, row.dataset.name, row); });
    });
    if (skuInput.value) {
      var prior = resultsBody.querySelector('tr[data-sku="' + skuInput.value.replace(/"/g, '\\"') + '"]');
      if (prior) prior.classList.add('selected');
    }

    renderPagination(page, pages, first, last, total);
  }

  // Window of page numbers around the current page. Keeps the strip compact
  // even with hundreds/thousands of pages.
  function pageWindow(page, total) {
    if (total <= 7) {
      var arr = [];
      for (var i = 1; i <= total; i++) arr.push(i);
      return arr;
    }
    var s = new Set([1, total, page - 1, page, page + 1]);
    if (page <= 3) { s.add(2); s.add(3); s.add(4); }
    if (page >= total - 2) { s.add(total - 1); s.add(total - 2); s.add(total - 3); }
    return [...s].filter(function (n) { return n >= 1 && n <= total; }).sort(function (a, b) { return a - b; });
  }

  function renderPagination(page, totalPages, first, last, total) {
    if (totalPages <= 1) {
      pagination.innerHTML = '<span class="ms-page-info">' + first + '–' + last + ' of ' + total + '</span>';
      return;
    }
    var win = pageWindow(page, totalPages);
    var html = '<span class="ms-page-info">' + first + '–' + last + ' of ' + total + '</span><div class="ms-page-buttons">';
    html += '<button data-page="' + (page - 1) + '" ' + (page === 1 ? 'disabled' : '') + '>‹ Prev</button>';
    var prev = 0;
    win.forEach(function (n) {
      if (prev && n - prev > 1) html += '<button disabled>…</button>';
      html += '<button data-page="' + n + '" class="' + (n === page ? 'active' : '') + '">' + n + '</button>';
      prev = n;
    });
    html += '<button data-page="' + (page + 1) + '" ' + (page === totalPages ? 'disabled' : '') + '>Next ›</button>';
    html += '</div>';
    pagination.innerHTML = html;
    Array.from(pagination.querySelectorAll('button[data-page]')).forEach(function (btn) {
      btn.addEventListener('click', function () {
        var p = parseInt(btn.dataset.page, 10);
        if (Number.isFinite(p) && p >= 1 && p <= totalPages && p !== page) {
          currentPage = p;
          runSearch();
          // Scroll the results into view so the user sees the new page.
          resultsWrap.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }
      });
    });
  }

  function pick(sku, name, row) {
    skuInput.value = sku;
    Array.from(resultsBody.querySelectorAll('tr.selected')).forEach(function (r) { r.classList.remove('selected'); });
    if (row) row.classList.add('selected');
    selected.style.display = '';
    selected.innerHTML = 'Reference selected: <strong>' + escHtml(name) + '</strong> ' +
                         '<span class="ms-mat">' + escHtml(sku) + '</span>' +
                         ' · <span class="ms-clear-link" id="ms-clear">clear</span>';
    document.getElementById('ms-clear').addEventListener('click', clearSelection);
  }
  function clearSelection() {
    skuInput.value = '';
    selected.style.display = 'none';
    Array.from(resultsBody.querySelectorAll('tr.selected')).forEach(function (r) { r.classList.remove('selected'); });
  }

  function escHtml(s) { return String(s == null ? '' : s).replace(/[<>&"']/g, function (c) { return { '<':'&lt;','>':'&gt;','&':'&amp;','"':'&quot;',"'":'&#39;' }[c]; }); }
  function escAttr(s) { return escHtml(s); }
})();
</script>
</div>
</body></html>
