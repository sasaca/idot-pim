<%- include('../partials/head', { pageTitle: 'Product Requests' }) %>
<%- include('../partials/nav') %>
<div class="main-content">
<%- include('../partials/topbar', { topTitle: 'Product Requests', topSub: 'All product master creation, variation and modification requests in flight.' }) %>

<main class="p-6">

<%- include('_product_tabs', { activeTab: activeTab || 'requests' }) %>

<form method="get" class="flex flex-wrap gap-2 mb-4">
  <input type="text" name="q" placeholder="Search ID, product name, type…" value="<%= query.q || '' %>" class="input max-w-xs">

  <select name="status" class="input max-w-[260px]">
    <option value="">All stages</option>
    <% Object.keys(stateLabels).forEach(function (s) { %>
      <option value="<%= s %>" <%= query.status === s ? 'selected' : '' %>><%= stateLabels[s] %></option>
    <% }); %>
  </select>

  <label class="inline-flex items-center gap-2 px-3 py-2 text-sm">
    <input type="checkbox" name="mine" value="1" <%= query.mine === '1' ? 'checked' : '' %>> My requests
  </label>

  <button class="btn btn-primary">Filter</button>
  <a href="/products" class="btn btn-ghost">Reset</a>
</form>

<div class="card">
  <div class="overflow-x-auto">
    <table class="data">
      <thead>
        <tr>
          <th>Request #</th>
          <th>Type</th>
          <th>Product</th>
          <th>Stage</th>
          <th>Assignee role</th>
          <th>Requestor</th>
          <th>Updated</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% if (!requests.length) { %>
          <tr><td colspan="8" class="text-center text-slate-500 p-10">No product requests match these filters.</td></tr>
        <% } %>
        <% requests.forEach(function (r) {
            var chip = 'bg-slate-100 text-slate-700';
            var s = r.workflow_state;
            if (s === 'CONFIRMED')                                          chip = 'bg-emerald-100 text-emerald-700';
            else if (s === 'REJECTED')                                      chip = 'bg-red-100 text-red-700';
            else if (s === 'NEEDS_INFO')                                    chip = 'bg-orange-100 text-orange-700';
            else if (s === 'DRAFT')                                         chip = 'bg-slate-100 text-slate-700';
            else if (s === 'PENDING_MKTG_DIRECTOR' || s === 'PENDING_SC_DIRECTOR'
                  || s === 'PENDING_RND_AND_QUALITY_DIRECTORS')             chip = 'bg-amber-100 text-amber-700';
            else                                                             chip = 'bg-blue-100 text-blue-700';
        %>
          <tr>
            <td class="font-mono text-xs">PR-<%= r.id %></td>
            <td class="text-xs text-slate-600"><%= (r.request_type || '').replace(/_/g, ' ') %></td>
            <td><%= r.product_name || '—' %></td>
            <td><span class="chip <%= chip %>"><%= r.state_label %></span></td>
            <td class="text-xs"><%= (r.assignee_role || '').replace(/_/g, ' ') %></td>
            <td class="text-xs text-slate-600"><%= r.requestor_full_name || r.requestor_name || '—' %></td>
            <td class="text-xs text-slate-500"><%= r.updated_at || '' %></td>
            <td><a href="<%= r.open_url %>" class="text-brand-600 hover:underline text-sm">Open →</a></td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>

</main>
</div>
</body></html>
