<%# _workflow_shared.ejs — shared header + history + comments for every product workflow view. Include with: include('_workflow_shared', { productRequest, stateLabel, history, comments }) %>
<div class="mb-6 rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
  <div class="flex items-start justify-between">
    <div>
      <h1 class="text-xl font-semibold text-gray-900">
        Product Request #<%= productRequest.id %> — <%= productRequest.product_name || '(unnamed)' %>
      </h1>
      <p class="mt-1 text-sm text-gray-500">
        <%= productRequest.request_type ? productRequest.request_type.replace(/_/g, ' ') : '' %>
        <% if (productRequest.requestor_name) { %>· requested by <%= productRequest.requestor_name %><% } %>
        <% if (productRequest.request_date) { %> on <%= productRequest.request_date %><% } %>
      </p>
      <p class="mt-2 text-sm text-gray-500">
        Current stage:
        <span class="ml-1 inline-flex items-center rounded-full bg-blue-50 px-2.5 py-0.5 text-xs font-medium text-blue-700">
          <%= stateLabel %>
        </span>
      </p>
    </div>
    <a href="/products/workflow/queue" class="text-sm text-blue-600 hover:underline">← Back to queue</a>
  </div>
</div>

<% if (Array.isArray(history) && history.length > 0) { %>
  <details class="mb-6 rounded-lg border border-gray-200 bg-gray-50 p-4">
    <summary class="cursor-pointer text-sm font-medium text-gray-700">
      Workflow history (<%= history.length %>)
    </summary>
    <ul class="mt-3 space-y-2 text-xs text-gray-600">
      <% history.forEach(function (h) { %>
        <li>
          <span class="font-mono"><%= h.created_at %></span> —
          <span class="font-medium"><%= h.action %></span>
          (<%= h.from_state %> → <%= h.to_state %>)
          <% if (h.actor_role) { %>by <%= h.actor_role %><% } %>
          <% if (h.actor_name) { %> (<%= h.actor_name %>)<% } %>
          <% if (h.reason_code) { %> — <strong><%= h.reason_code %></strong><% } %>
          <% if (h.note) { %> — <em><%= h.note %></em><% } %>
        </li>
      <% }); %>
    </ul>
  </details>
<% } %>

<% if (Array.isArray(comments) && comments.length > 0) { %>
  <div class="mb-6 rounded-lg border border-amber-200 bg-amber-50 p-4">
    <h3 class="text-sm font-semibold text-amber-900">Comments</h3>
    <ul class="mt-2 space-y-2 text-sm text-amber-900">
      <% comments.forEach(function (c) { %>
        <li>
          <span class="text-xs text-amber-700">[<%= c.author_role || 'anon' %> · <%= c.created_at %>]</span>
          <%= c.body %>
        </li>
      <% }); %>
    </ul>
  </div>
<% } %>
