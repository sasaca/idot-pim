<%- include('../partials/head', { pageTitle: 'Product Request Queue' }) %>
<%- include('../partials/nav') %>
<div class="main-content">
<%- include('../partials/topbar', { topTitle: 'Product Request Queue', topSub: 'Active product creation requests filtered by your role.' }) %>

<main class="mx-auto max-w-7xl px-4 py-6">
  <div class="mb-4 flex items-center justify-between">
    <p class="text-sm text-gray-600">
      Showing requests in:
      <% states.forEach(function (s, i) { %>
        <span class="ml-1 inline-flex items-center rounded-full bg-blue-50 px-2.5 py-0.5 text-xs font-medium text-blue-700">
          <%= stateLabels[s] || s %>
        </span>
      <% }); %>
    </p>
    <a href="/products/workflow/new" class="rounded bg-blue-700 px-4 py-2 text-sm font-medium text-white hover:bg-blue-800">+ New product request</a>
  </div>

  <% if (!requests || requests.length === 0) { %>
    <div class="rounded-lg border border-dashed border-gray-300 bg-gray-50 p-10 text-center text-sm text-gray-500">
      Nothing in your queue right now.
    </div>
  <% } else { %>
    <div class="overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
      <table class="min-w-full divide-y divide-gray-200 text-sm">
        <thead class="bg-gray-50 text-xs uppercase tracking-wider text-gray-600">
          <tr>
            <th class="px-4 py-2 text-left">#</th>
            <th class="px-4 py-2 text-left">Product</th>
            <th class="px-4 py-2 text-left">Type</th>
            <th class="px-4 py-2 text-left">Requestor</th>
            <th class="px-4 py-2 text-left">Stage</th>
            <th class="px-4 py-2 text-left">Updated</th>
            <th class="px-4 py-2"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% requests.forEach(function (r) { %>
            <%
              var deepLink = '/products/workflow/' + r.id + '/confirmation';
              var roles = (typeof viewerRoles !== 'undefined' && viewerRoles) ? viewerRoles : [];
              if      (r.workflow_state === 'DRAFT' || r.workflow_state === 'NEEDS_INFO') deepLink = '/products/workflow/' + r.id + '/details';
              else if (r.workflow_state === 'PENDING_MKTG_DIRECTOR') deepLink = '/products/workflow/' + r.id + '/mktg-director';
              else if (r.workflow_state === 'PENDING_SC_DIRECTOR')   deepLink = '/products/workflow/' + r.id + '/sc-director';
              else if (r.workflow_state === 'PENDING_PRODUCTION_AND_ANALYSIS') {
                if (roles.indexOf('RND_TEAM') >= 0) {
                  if      (!r.production_completed_at) deepLink = '/products/workflow/' + r.id + '/production';
                  else if (!r.packaging_completed_at)  deepLink = '/products/workflow/' + r.id + '/packaging';
                  else if (!r.design_completed_at)     deepLink = '/products/workflow/' + r.id + '/design';
                  else deepLink = '/products/workflow/' + r.id + '/confirmation';
                }
                else if (roles.indexOf('MARKETING_TEAM') >= 0) deepLink = '/products/workflow/' + r.id + '/competitor';
                else deepLink = '/products/workflow/' + r.id + '/confirmation';
              }
            %>
            <tr class="hover:bg-gray-50">
              <td class="px-4 py-2 font-mono text-xs text-gray-500"><%= r.id %></td>
              <td class="px-4 py-2 font-medium text-gray-900"><%= r.product_name || '—' %></td>
              <td class="px-4 py-2 text-gray-600"><%= r.request_type ? r.request_type.replace(/_/g,' ') : '—' %></td>
              <td class="px-4 py-2 text-gray-600"><%= r.requestor_full_name || r.requestor_name || '—' %></td>
              <td class="px-4 py-2">
                <span class="inline-flex items-center rounded-full bg-blue-50 px-2.5 py-0.5 text-xs font-medium text-blue-700">
                  <%= stateLabels[r.workflow_state] || r.workflow_state %>
                </span>
              </td>
              <td class="px-4 py-2 text-xs text-gray-500"><%= r.updated_at %></td>
              <td class="px-4 py-2 text-right">
                <a href="<%= deepLink %>" class="text-blue-600 hover:underline text-sm">Open →</a>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  <% } %>
</main>
</div>
</body></html>
