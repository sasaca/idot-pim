<%- include('../partials/head', { pageTitle: 'Product Request — Confirmation' }) %>
<%- include('../partials/nav') %>
<div class="main-content">
<%- include('../partials/topbar', { topTitle: 'Product Request', topSub: 'Final state and audit trail.' }) %>

<main class="mx-auto max-w-5xl px-4 py-8">
  <%- include('_workflow_shared', { productRequest: productRequest, stateLabel: stateLabel, history: history, comments: comments }) %>

  <%
    var fromAction = (typeof query !== 'undefined' && query && query.from) ? String(query.from) : '';
    var actionLabel = {
      submit_details:               'Submitted for Marketing Director approval',
      mktg_approve:                 'Marketing Director approval recorded',
      mktg_reject:                  'Marketing Director rejection recorded',
      mktg_request_info:            'Sent back to the requestor for more information',
      sc_approve:                   'Supply Chain Director approved — Production & Competitor Analysis are now open',
      sc_reject:                    'Supply Chain Director rejection recorded',
      sc_request_info:              'Sent back to the requestor for more information',
      submit_production:            'Production submitted by R&D — Packaging Materials and Design are now open',
      submit_packaging_partial:     'Packaging Materials submitted by R&D — other tracks still pending',
      submit_packaging_final:       'Packaging Materials submitted — BOM selection now opens for R&D',
      submit_design_partial:        'Design submitted by R&D — other tracks still pending',
      submit_design_final:          'Design submitted — BOM selection now opens for R&D',
      submit_competitor_partial:    'Competitor analysis submitted — other tracks still pending',
      submit_competitor_final:      'Competitor analysis submitted — BOM selection now opens for R&D',
      submit_bom:                   'BOM submitted by R&D — sent to R&D Director and Quality Director for parallel approval',
      rnd_dir_approve_partial:      'R&D Director approval recorded — waiting on Quality Director',
      rnd_dir_approve_final:        'R&D Director approval recorded — Legal + MDM tasks now open',
      rnd_dir_reject:               'R&D Director rejection recorded',
      rnd_dir_request_info:         'R&D Director sent the request back for more information',
      quality_dir_approve_partial:  'Quality Director approval recorded — waiting on R&D Director',
      quality_dir_approve_final:    'Quality Director approval recorded — Legal + MDM tasks now open',
      quality_dir_reject:           'Quality Director rejection recorded',
      quality_dir_request_info:     'Quality Director sent the request back for more information',
      submit_legal_partial:         'Legal submitted — waiting on MDM',
      submit_legal_final:           'Legal submitted — request confirmed',
      submit_mdm_partial:           'MDM submitted — waiting on Legal',
      submit_mdm_final:             'MDM submitted — request confirmed',
    }[fromAction];
  %>

  <% if (productRequest.workflow_state === 'CONFIRMED') { %>
    <section class="rounded-lg border border-green-200 bg-green-50 p-8 text-center shadow-sm">
      <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-green-100">
        <svg viewBox="0 0 20 20" fill="#16a34a" class="h-8 w-8">
          <path fill-rule="evenodd" d="M16.7 5.3a1 1 0 010 1.4l-7 7a1 1 0 01-1.4 0l-3-3a1 1 0 111.4-1.4L9 11.6l6.3-6.3a1 1 0 011.4 0z" clip-rule="evenodd"/>
        </svg>
      </div>
      <h2 class="text-2xl font-semibold text-green-900">Product request confirmed</h2>
      <p class="mt-2 text-green-800">
        <strong><%= productRequest.product_name %></strong> has been approved by both
        Marketing and Supply Chain Directors. The payload is now ready to be
        sent to SAP S/4HANA for material master creation.
      </p>
      <div class="mt-6 flex justify-center gap-3">
        <a href="/products/workflow/queue" class="rounded bg-green-600 px-4 py-2 text-sm font-medium text-white hover:bg-green-700">Back to queue</a>
      </div>
    </section>
  <% } else if (productRequest.workflow_state === 'REJECTED') { %>
    <section class="rounded-lg border border-red-200 bg-red-50 p-8 shadow-sm">
      <h2 class="text-xl font-semibold text-red-900">Request rejected</h2>
      <p class="mt-2 text-sm text-red-800">
        This request was rejected. A new request must be started to try again.
        Review the comments above for the reason.
      </p>
      <div class="mt-6">
        <a href="/products/workflow/new" class="rounded bg-red-600 px-4 py-2 text-sm font-medium text-white hover:bg-red-700">Start a new request</a>
      </div>
    </section>
  <% } else if (fromAction && actionLabel) { %>
    <section class="mb-4 rounded-lg border border-emerald-200 bg-emerald-50 p-6 shadow-sm">
      <div class="flex items-start gap-3">
        <span class="text-emerald-600 text-2xl">✓</span>
        <div class="flex-1">
          <h2 class="text-lg font-semibold text-emerald-900"><%= actionLabel %></h2>
          <p class="mt-1 text-sm text-emerald-800">
            <strong><%= productRequest.product_name || ('Request #' + productRequest.id) %></strong>
            is now at stage
            <span class="ml-1 inline-flex items-center rounded-full bg-emerald-100 px-2 py-0.5 text-xs font-medium text-emerald-700"><%= stateLabel %></span>.
          </p>
        </div>
      </div>
      <div class="mt-4 flex flex-wrap gap-2">
        <a href="/products/workflow/queue" class="rounded bg-emerald-600 px-4 py-2 text-sm font-medium text-white hover:bg-emerald-700">Queue</a>
      </div>
    </section>
  <% } else { %>
    <section class="rounded-lg border border-gray-200 bg-white p-8 shadow-sm">
      <h2 class="text-lg font-semibold text-gray-900">Workflow in progress</h2>
      <p class="mt-2 text-sm text-gray-600">
        This request is currently at stage <strong><%= stateLabel %></strong>.
      </p>
      <% if (productRequest.workflow_state === 'PENDING_PRODUCTION_AND_ANALYSIS') { %>
        <div class="mt-4 grid grid-cols-2 lg:grid-cols-4 gap-3 text-sm">
          <div class="rounded border <%= productRequest.production_completed_at ? 'border-green-200 bg-green-50 text-green-900' : 'border-amber-200 bg-amber-50 text-amber-900' %> p-3">
            <strong>Production (R&amp;D)</strong>
            <% if (productRequest.production_completed_at) { %>
              · ✓ submitted <%= productRequest.production_completed_at %>
            <% } else { %>· pending<% } %>
          </div>
          <div class="rounded border <%= productRequest.packaging_completed_at ? 'border-green-200 bg-green-50 text-green-900' : 'border-amber-200 bg-amber-50 text-amber-900' %> p-3">
            <strong>Packaging Materials (R&amp;D)</strong>
            <% if (productRequest.packaging_completed_at) { %>
              · ✓ submitted <%= productRequest.packaging_completed_at %>
            <% } else if (productRequest.production_completed_at) { %>· in progress<% } else { %>· waiting on Production<% } %>
          </div>
          <div class="rounded border <%= productRequest.design_completed_at ? 'border-green-200 bg-green-50 text-green-900' : 'border-amber-200 bg-amber-50 text-amber-900' %> p-3">
            <strong>Design (R&amp;D)</strong>
            <% if (productRequest.design_completed_at) { %>
              · ✓ submitted <%= productRequest.design_completed_at %>
            <% } else if (productRequest.production_completed_at) { %>· in progress<% } else { %>· waiting on Production<% } %>
          </div>
          <div class="rounded border <%= productRequest.competitor_completed_at ? 'border-green-200 bg-green-50 text-green-900' : 'border-amber-200 bg-amber-50 text-amber-900' %> p-3">
            <strong>Competitor Analysis (Marketing)</strong>
            <% if (productRequest.competitor_completed_at) { %>
              · ✓ submitted <%= productRequest.competitor_completed_at %>
            <% } else { %>· pending<% } %>
          </div>
        </div>
      <% } %>
    </section>
  <% } %>

  <% if (productRequest.workflow_state === 'PENDING_BOM') { %>
    <section class="rounded-lg border border-blue-200 bg-blue-50 p-6 mt-4 shadow-sm">
      <h2 class="text-lg font-semibold text-blue-900">Awaiting BOM selection</h2>
      <p class="mt-2 text-sm text-blue-800">
        All preliminary tracks are complete. R&amp;D needs to finalize the
        Packaging and Formula BOMs before the request can be confirmed.
      </p>
      <% if (currentUser && (currentUser.role === 'RND_TEAM' || currentUser.role === 'MASTER_ADMIN')) { %>
        <a href="/products/workflow/<%= productRequest.id %>/bom" class="mt-3 inline-block rounded bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">Open BOM tab →</a>
      <% } %>
    </section>
  <% } %>

  <% if (productRequest.workflow_state === 'PENDING_LEGAL_AND_MDM') { %>
    <section class="rounded-lg border border-blue-200 bg-blue-50 p-6 mt-4 shadow-sm">
      <h2 class="text-lg font-semibold text-blue-900">Awaiting Legal &amp; MDM tasks</h2>
      <p class="mt-2 text-sm text-blue-800">
        Both directors approved. Legal and MDM teams now work in parallel —
        the request only confirms once both submit.
      </p>
      <div class="mt-4 grid grid-cols-2 gap-3 text-sm">
        <div class="rounded border <%= productRequest.legal_completed_at ? 'border-green-200 bg-green-50 text-green-900' : 'border-amber-200 bg-amber-50 text-amber-900' %> p-3">
          <strong>Legal</strong>
          <% if (productRequest.legal_completed_at) { %>· ✓ submitted <%= productRequest.legal_completed_at %><% } else { %>· pending<% } %>
        </div>
        <div class="rounded border <%= productRequest.mdm_completed_at ? 'border-green-200 bg-green-50 text-green-900' : 'border-amber-200 bg-amber-50 text-amber-900' %> p-3">
          <strong>MDM material review</strong>
          <% if (productRequest.mdm_completed_at) { %>· ✓ submitted <%= productRequest.mdm_completed_at %><% } else { %>· pending<% } %>
        </div>
      </div>
      <% if (currentUser) { %>
        <% if (currentUser.role === 'LEGAL' && !productRequest.legal_completed_at) { %>
          <a href="/products/workflow/<%= productRequest.id %>/legal" class="mt-3 inline-block rounded bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">Open Legal task →</a>
        <% } else if (currentUser.role === 'MDM_TEAM' && !productRequest.mdm_completed_at) { %>
          <a href="/products/workflow/<%= productRequest.id %>/mdm" class="mt-3 inline-block rounded bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">Open MDM review →</a>
        <% } %>
      <% } %>
    </section>
  <% } %>

  <% if (productRequest.workflow_state === 'PENDING_RND_AND_QUALITY_DIRECTORS') { %>
    <section class="rounded-lg border border-blue-200 bg-blue-50 p-6 mt-4 shadow-sm">
      <h2 class="text-lg font-semibold text-blue-900">Awaiting director approvals</h2>
      <p class="mt-2 text-sm text-blue-800">
        R&amp;D Director and Quality Director must each approve in parallel
        before the request is confirmed.
      </p>
      <div class="mt-4 grid grid-cols-2 gap-3 text-sm">
        <div class="rounded border <%= productRequest.rnd_director_approved_at ? 'border-green-200 bg-green-50 text-green-900' : 'border-amber-200 bg-amber-50 text-amber-900' %> p-3">
          <strong>R&amp;D Director</strong>
          <% if (productRequest.rnd_director_approved_at) { %>
            · ✓ approved <%= productRequest.rnd_director_approved_at %>
          <% } else { %>· pending<% } %>
        </div>
        <div class="rounded border <%= productRequest.quality_director_approved_at ? 'border-green-200 bg-green-50 text-green-900' : 'border-amber-200 bg-amber-50 text-amber-900' %> p-3">
          <strong>Quality Director</strong>
          <% if (productRequest.quality_director_approved_at) { %>
            · ✓ approved <%= productRequest.quality_director_approved_at %>
          <% } else { %>· pending<% } %>
        </div>
      </div>
      <% if (currentUser) { %>
        <% if (currentUser.role === 'RND_DIRECTOR' && !productRequest.rnd_director_approved_at) { %>
          <a href="/products/workflow/<%= productRequest.id %>/rnd-director" class="mt-3 inline-block rounded bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">Open R&amp;D Director review →</a>
        <% } else if (currentUser.role === 'QUALITY_DIRECTOR' && !productRequest.quality_director_approved_at) { %>
          <a href="/products/workflow/<%= productRequest.id %>/quality-director" class="mt-3 inline-block rounded bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">Open Quality Director review →</a>
        <% } %>
      <% } %>
    </section>
  <% } %>

  <% if (['PENDING_PRODUCTION_AND_ANALYSIS','PENDING_BOM','PENDING_RND_AND_QUALITY_DIRECTORS','PENDING_LEGAL_AND_MDM','CONFIRMED','REJECTED'].includes(productRequest.workflow_state)) { %>
    <div class="mt-6">
      <%- include('_readonly_view', {
        productRequest: productRequest, ref: ref,
        attachments:       (typeof attachments       !== 'undefined' ? attachments       : []),
        designAttachments: (typeof designAttachments !== 'undefined' ? designAttachments : []),
        legalAttachments:  (typeof legalAttachments  !== 'undefined' ? legalAttachments  : [])
      }) %>
    </div>
  <% } %>
</main>
</div>
</body></html>
