<%- include('../partials/head', { pageTitle: 'Update ' + product.name }) %>
<%- include('../partials/nav') %>
<div class="main-content">
<%- include('../partials/topbar', { topTitle: 'Update: ' + product.name, topSub: 'Product update request · requires approval' }) %>
<main class="p-6 max-w-3xl">

<form method="post" action="/products/<%= product.id %>/update" class="space-y-6">
  <section class="card">
    <div class="card-header"><h3 class="font-semibold">Product update</h3></div>
    <div class="card-body grid grid-cols-1 md:grid-cols-2 gap-4">
      <label class="field"><span class="label">Name</span><input name="name" value="<%= product.name %>" class="input"></label>
      <label class="field"><span class="label">Description</span><input name="description" value="<%= product.description || '' %>" class="input"></label>
      <label class="field"><span class="label">Material group</span>
        <select name="material_group" class="input">
          <% (ref.MATERIAL_GROUP || []).forEach(c => { %><option value="<%= c.code %>" <%= product.material_group===c.code ? 'selected':'' %>><%= c.label %></option><% }) %>
        </select></label>
      <label class="field"><span class="label">Lifecycle</span>
        <select name="lifecycle_status" class="input">
          <% ['NEW','ACTIVE','PHASE_OUT','OBSOLETE','BLOCKED'].forEach(s => { %><option value="<%= s %>" <%= product.lifecycle_status===s ? 'selected':'' %>><%= s %></option><% }) %>
        </select></label>
      <label class="field"><span class="label">Net weight</span><input name="net_weight" type="number" step="0.001" value="<%= product.net_weight || '' %>" class="input"></label>
      <label class="field"><span class="label">Standard price</span><input name="standard_price" type="number" step="0.0001" value="<%= product.standard_price || '' %>" class="input"></label>
    </div>
  </section>
  <section class="card">
    <div class="card-header"><h3 class="font-semibold">Justification</h3></div>
    <div class="card-body">
      <label class="field"><span class="label">Reason *</span>
        <textarea name="reason" rows="3" required class="input"></textarea></label>
    </div>
  </section>
  <div class="flex gap-2">
    <button class="btn btn-primary">Submit for approval →</button>
    <a href="/products/<%= product.id %>" class="btn btn-ghost">Cancel</a>
  </div>
</form>

</main></div>
</body></html>
