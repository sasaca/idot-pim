<%
/*
  views/products/_approval_form.ejs
  ---------------------------------------------------------------------------
  Three-button approval footer used by both director approval views. Caller
  passes the form action URL, the action prefix ('mktg' | 'sc'), and the
  applicable reason lists.

  Required locals:
    formAction      string           — POST url
    actionPrefix    string           — 'mktg' or 'sc'
    rejectReasons   string[]
    infoReasons     string[]
*/
%>
<style>
  .ap-card { background:#fff; border:1px solid #e5e7eb; border-radius:8px; padding:18px 22px; box-shadow:0 1px 2px rgba(0,0,0,.04); margin-top:18px; }
  .ap-card h2 { font-size:15px; font-weight:600; color:#111827; margin:0 0 14px; padding-bottom:6px; border-bottom:1px solid #e5e7eb; }
  .ap-row { display:flex; gap:1rem; flex-wrap:wrap; align-items:flex-start; }
  .ap-card .ap-action-card {
    flex:1 1 220px; border:1px solid #e5e7eb; border-radius:8px; padding:14px 16px;
    display:flex; flex-direction:column; gap:8px; background:#fafafa;
  }
  .ap-card .ap-action-card.approve { border-color:#bbf7d0; background:#f0fdf4; }
  .ap-card .ap-action-card.reject  { border-color:#fecaca; background:#fef2f2; }
  .ap-card .ap-action-card.info    { border-color:#fde68a; background:#fffbeb; }
  .ap-action-card h3 { font-size:13px; font-weight:600; margin:0; }
  .ap-action-card.approve h3 { color:#166534; }
  .ap-action-card.reject  h3 { color:#991b1b; }
  .ap-action-card.info    h3 { color:#92400e; }
  .ap-action-card label { font-size:12px; color:#374151; font-weight:500; }
  .ap-action-card select, .ap-action-card textarea { width:100%; padding:7px 9px; border:1px solid #d1d5db; border-radius:5px; font-size:13px; box-sizing:border-box; }
  .ap-action-card textarea { min-height:64px; resize:vertical; }
  .ap-action-card button {
    padding:.55rem 1rem; border:none; border-radius:.4rem; font-size:13px; font-weight:600;
    cursor:pointer; color:white;
  }
  .ap-action-card.approve button { background:#16a34a; }
  .ap-action-card.approve button:hover { background:#15803d; }
  .ap-action-card.reject  button { background:#dc2626; }
  .ap-action-card.reject  button:hover { background:#b91c1c; }
  .ap-action-card.info    button { background:#d97706; }
  .ap-action-card.info    button:hover { background:#b45309; }
</style>

<div class="ap-card">
  <h2>Decision</h2>
  <div class="ap-row">

    <!-- Reject -->
    <form method="post" action="<%= formAction %>" class="ap-action-card reject">
      <h3>✗ Reject</h3>
      <label>Reason</label>
      <select name="reason_code" required>
        <option value="">-- Select reason --</option>
        <% rejectReasons.forEach(function (r) { %><option><%= r %></option><% }); %>
      </select>
      <label>Rationale (optional)</label>
      <textarea name="note" placeholder="Add detail for the requestor (optional)"></textarea>
      <button type="submit" name="action" value="<%= actionPrefix %>_reject"
              onclick="return confirm('Reject this product request? This is terminal — a new submission would be required to retry.');">
        Reject
      </button>
    </form>

    <!-- Request more info -->
    <form method="post" action="<%= formAction %>" class="ap-action-card info">
      <h3>? Request more information</h3>
      <label>Reason</label>
      <select name="reason_code" required>
        <option value="">-- Select reason --</option>
        <% infoReasons.forEach(function (r) { %><option><%= r %></option><% }); %>
      </select>
      <label>Rationale (optional)</label>
      <textarea name="note" placeholder="What does the requestor need to clarify? (optional)"></textarea>
      <button type="submit" name="action" value="<%= actionPrefix %>_request_info">Send back to requestor</button>
    </form>

    <!-- Approve -->
    <form method="post" action="<%= formAction %>" class="ap-action-card approve">
      <h3>✓ Approve</h3>
      <label>Note (optional)</label>
      <textarea name="note" placeholder="Optional approval note"></textarea>
      <button type="submit" name="action" value="<%= actionPrefix %>_approve">Approve</button>
    </form>
  </div>
</div>
