<%- include('../partials/head', { pageTitle: 'Wrong state' }) %>
<%- include('../partials/nav') %>
<div class="main-content">
<%- include('../partials/topbar', { topTitle: 'Cannot perform this action', topSub: '' }) %>

<main class="mx-auto max-w-2xl px-4 py-10">
  <div class="rounded-lg border border-amber-200 bg-amber-50 p-8 shadow-sm">
    <h1 class="text-xl font-semibold text-amber-900">This request is not in the right state</h1>
    <p class="mt-3 text-sm text-amber-800">
      Product Request #<%= productRequest.id %> (<%= productRequest.product_name || '' %>)
      is currently in <strong><%= current %></strong>, but this page requires it to be in
      <% required.forEach(function (s, i) { %><strong><%= s %></strong><%= (i < required.length - 1) ? ' or ' : '' %><% }); %>.
    </p>
    <div class="mt-6 flex gap-3">
      <a href="/products/workflow/<%= productRequest.id %>/confirmation" class="rounded bg-amber-600 px-4 py-2 text-sm font-medium text-white hover:bg-amber-700">View current status</a>
      <a href="/products/workflow/queue" class="rounded border border-amber-300 px-4 py-2 text-sm text-amber-800 hover:bg-amber-100">Back to queue</a>
    </div>
  </div>
</main>
</div>
</body></html>
