<%
/*
  _bom_row.ejs — single editable BOM row for the workflow_bom view.
  Caller passes `r` (the row object) and `prefix` ('pkg' | 'frm' or '__P__'
  when used as a JS template).
*/
var v = r.vendor || {};
%>
<tr class="row-<%= r.source || 'NEW' %>">
  <td>
    <input type="hidden" name="<%= prefix %>_source" value="<%= r.source || 'NEW' %>" data-src-input>
    <span class="src-pill <%= r.source || 'NEW' %>" data-src-pill><%= r.source || 'NEW' %></span>
  </td>
  <td><input type="text" name="<%= prefix %>_material_number"      value="<%= r.material_number      || '' %>" placeholder="MATXXXXX"></td>
  <td><input type="text" name="<%= prefix %>_material_description" value="<%= r.material_description || '' %>" placeholder="Description" required></td>
  <td><input type="text" name="<%= prefix %>_category_name"        value="<%= r.category_name        || '' %>"></td>
  <td><input type="text" name="<%= prefix %>_brand"                value="<%= r.brand                || '' %>"></td>
  <td><input type="text" name="<%= prefix %>_material_group"       value="<%= r.material_group       || '' %>"></td>
  <td><input type="text" name="<%= prefix %>_material_type"        value="<%= r.material_type        || '' %>" class="short" placeholder="ROH/VERP"></td>
  <td><input type="text" name="<%= prefix %>_base_uom"             value="<%= r.base_uom             || '' %>" class="short" placeholder="EA"></td>
  <td><input type="text" name="<%= prefix %>_division"             value="<%= r.division             || '' %>" class="short" placeholder="50"></td>
  <td><input type="number" step="0.0001" min="0" name="<%= prefix %>_volume"   value="<%= r.volume   != null ? r.volume   : '' %>" class="short"></td>
  <td><input type="number" step="0.0001" min="0" name="<%= prefix %>_quantity" value="<%= r.quantity != null ? r.quantity : '' %>" class="short" required></td>
  <td class="col-actions row-actions">
    <button type="button" data-branch title="Branch as new variant">🌿</button>
    <button type="button" data-remove class="rm" title="Remove row">✕</button>
  </td>
</tr>
<tr class="vendor-row">
  <td colspan="12" style="border-bottom:1px solid #e5e7eb;">
    <div class="vendor-block" data-vendor-block style="display:<%= r.source === 'NEW' ? 'block' : 'none' %>;">
      <div class="vt-row">
        <strong style="font-size:11px; color:#92400e;">Vendor</strong>
        <label style="margin-left:8px;"><input type="radio" name="<%= prefix %>_vendor_type" value="EXISTING" <%= (v.type === 'NEW' ? '' : 'checked') %> data-vendor-type> Existing vendor</label>
        <label style="margin-left:8px;"><input type="radio" name="<%= prefix %>_vendor_type" value="NEW"      <%= (v.type === 'NEW' ? 'checked' : '') %> data-vendor-type> New vendor</label>
      </div>
      <div class="vendor-fields">
        <div data-vendor-existing>
          <label>Vendor code</label>
          <input type="text" name="<%= prefix %>_vendor_code" value="<%= v.vendor_code || '' %>" placeholder="ERP supplier code">
        </div>
        <div data-vendor-new>
          <label>Vendor name</label>
          <input type="text" name="<%= prefix %>_vendor_name"    value="<%= v.name    || '' %>" placeholder="Supplier legal name">
        </div>
        <div data-vendor-new>
          <label>Contact</label>
          <input type="text" name="<%= prefix %>_vendor_contact" value="<%= v.contact || '' %>" placeholder="Primary contact">
        </div>
        <div data-vendor-new>
          <label>Email</label>
          <input type="email" name="<%= prefix %>_vendor_email"  value="<%= v.email   || '' %>" placeholder="email@vendor.com">
        </div>
        <div data-vendor-new>
          <label>Phone</label>
          <input type="tel" name="<%= prefix %>_vendor_phone"    value="<%= v.phone   || '' %>" placeholder="+1 555 1234">
        </div>
      </div>
    </div>
  </td>
</tr>
