<%
/*
  views/products/_product_tabs.ejs
  Two-tab strip shared by /products (Requests) and /products/dashboard. Caller
  passes activeTab = 'requests' | 'dashboard' so the right tab gets the
  active style.
*/
%>
<style>
  /* Underline-style tab strip, prominent and full-width-aware. */
  .pt-tabs-wrap { border-bottom: 2px solid #e2e8f0; margin-bottom: 1.25rem; }
  .pt-tabs { display: flex; gap: 8px; }
  .pt-tabs a {
    position: relative; bottom: -2px;
    display: inline-flex; align-items: center; gap: 8px;
    padding: 10px 18px; font-size: 14px; font-weight: 600;
    color: #64748b; text-decoration: none;
    border-bottom: 2px solid transparent;
    transition: color .12s ease, border-color .12s ease;
  }
  .pt-tabs a:hover { color: #1e3a8a; }
  .pt-tabs a.active { color: #1e3a8a; border-bottom-color: #1e3a8a; }
  .pt-tabs a .icon { font-size: 16px; }
</style>
<div class="pt-tabs-wrap">
  <nav class="pt-tabs">
    <a href="/products/dashboard" class="<%= activeTab === 'dashboard' ? 'active' : '' %>">
      <span class="icon">📊</span> Product Dashboard
    </a>
    <a href="/products" class="<%= activeTab === 'requests' ? 'active' : '' %>">
      <span class="icon">📋</span> Product Requests
    </a>
  </nav>
</div>
