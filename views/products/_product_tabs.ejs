<%
/*
  views/products/_product_tabs.ejs
  Two-tab strip shared by /products (Requests) and /products/dashboard. Caller
  passes activeTab = 'requests' | 'dashboard' so the right tab gets the
  active style.
*/
%>
<style>
  .pt-tabs {
    display: inline-flex; gap: 4px; padding: 4px; margin-bottom: 1rem;
    background: #f1f5f9; border-radius: 8px;
  }
  .pt-tabs a {
    padding: 7px 16px; font-size: 13px; font-weight: 500;
    color: #475569; border-radius: 6px; text-decoration: none;
  }
  .pt-tabs a:hover { color: #0f172a; background: #e2e8f0; }
  .pt-tabs a.active {
    background: #1e3a8a; color: white; box-shadow: 0 1px 2px rgba(0,0,0,.08);
  }
</style>
<nav class="pt-tabs">
  <a href="/products"           class="<%= activeTab === 'requests'  ? 'active' : '' %>">Product Requests</a>
  <a href="/products/dashboard" class="<%= activeTab === 'dashboard' ? 'active' : '' %>">Product Dashboard</a>
</nav>
