<%- include('../partials/head', { pageTitle: 'Create Product' }) %>
<%- include('../partials/nav') %>
<div class="main-content">
<%- include('../partials/topbar', { topTitle: 'Create Product', topSub: 'Submit a new product / material master creation request.' }) %>
<main class="p-6 max-w-5xl">


<%- include('../partials/doc_upload', { docDomain: 'PRODUCT_CREATE', docTitle: 'Document Upload — Product Creation' }) %>

<form method="post" action="/products/new/create" class="space-y-6">

  <section class="card">
    <div class="card-header"><h3 class="font-semibold">1. Product identity</h3></div>
    <div class="card-body grid grid-cols-1 md:grid-cols-2 gap-4">
      <label class="field"><span class="label">Product name *</span><input name="name" required class="input"></label>
      <label class="field"><span class="label">SKU / Material # (leave blank to auto-assign)</span><input name="sku" class="input"></label>
      <label class="field md:col-span-2"><span class="label">Description *</span>
        <textarea name="description" rows="2" required class="input"></textarea></label>
    </div>
  </section>

  <section class="card">
    <div class="card-header"><h3 class="font-semibold">2. Classification</h3></div>
    <div class="card-body grid grid-cols-1 md:grid-cols-2 gap-4">
      <label class="field"><span class="label">Product type *</span>
        <select name="product_type" required class="input">
          <option value="">—</option>
          <% (ref.PRODUCT_TYPE || []).forEach(c => { %><option value="<%= c.code %>"><%= c.label %></option><% }) %>
        </select></label>
      <label class="field"><span class="label">Material group *</span>
        <select name="material_group" required class="input">
          <option value="">—</option>
          <% (ref.MATERIAL_GROUP || []).forEach(c => { %><option value="<%= c.code %>"><%= c.label %></option><% }) %>
        </select></label>
      <label class="field"><span class="label">Industry sector</span>
        <select name="industry_sector" class="input"><option>INDUSTRIAL</option><option>CONSUMER</option><option>CONSTRUCTION</option><option>TECHNOLOGY</option></select></label>
      <label class="field"><span class="label">Division</span><input name="division" class="input"></label>
      <label class="field"><span class="label">Base UoM *</span>
        <select name="base_uom" required class="input">
          <% (ref.UOM || []).forEach(c => { %><option value="<%= c.code %>"><%= c.code %> — <%= c.label %></option><% }) %>
        </select></label>
      <label class="field"><span class="label">Country of origin</span>
        <select name="country_of_origin" class="input">
          <option value="">—</option>
          <% (ref.COUNTRY || []).forEach(c => { %><option value="<%= c.code %>"><%= c.label %></option><% }) %>
        </select></label>
    </div>
  </section>

  <section class="card">
    <div class="card-header"><h3 class="font-semibold">3. Physical attributes</h3></div>
    <div class="card-body grid grid-cols-1 md:grid-cols-2 gap-4">
      <label class="field"><span class="label">Net weight</span><input name="net_weight" type="number" step="0.001" class="input"></label>
      <label class="field"><span class="label">Gross weight</span><input name="gross_weight" type="number" step="0.001" class="input"></label>
      <label class="field"><span class="label">Weight UoM</span>
        <select name="weight_uom" class="input"><option>KG</option><option>LB</option><option>G</option></select></label>
      <label class="field"><span class="label">Volume</span><input name="volume" type="number" step="0.001" class="input"></label>
      <label class="field"><span class="label">Volume UoM</span>
        <select name="volume_uom" class="input"><option>L</option><option>M3</option><option>FT3</option></select></label>
      <label class="field"><span class="label">HTS / HS code</span><input name="hts_code" class="input"></label>
    </div>
  </section>

  <section class="card">
    <div class="card-header"><h3 class="font-semibold">4. Plant / procurement</h3></div>
    <div class="card-body grid grid-cols-1 md:grid-cols-2 gap-4">
      <label class="field"><span class="label">Procurement type</span>
        <select name="procurement_type" class="input"><option>IN_HOUSE</option><option>EXTERNAL</option><option>BOTH</option></select></label>
      <label class="field"><span class="label">MRP type</span>
        <select name="mrp_type" class="input"><option>ND</option><option>PD</option><option>VB</option></select></label>
      <label class="field"><span class="label">Lot size</span>
        <select name="lot_size" class="input"><option>EX</option><option>FX</option><option>PK</option></select></label>
      <label class="field"><span class="label">Plant</span><input name="plant" class="input"></label>
      <label class="field"><span class="label">Valuation class</span><input name="valuation_class" class="input"></label>
      <label class="field"><span class="label">Standard price</span><input name="standard_price" type="number" step="0.0001" class="input"></label>
    </div>
  </section>

  <div class="flex gap-2">
    <button class="btn btn-primary">Submit creation request →</button>
    <a href="/products" class="btn btn-ghost">Cancel</a>
  </div>
</form>
</main></div>
</body></html>
