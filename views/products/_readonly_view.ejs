<%
/*
  views/products/_readonly_view.ejs
  ---------------------------------------------------------------------------
  Read-only data viewer used by every approval screen + the confirmation
  page. Each submitted form gets its own item in the LEFT NAV; clicking
  switches the right pane. Forms with multiple tabs (Stage 2, Production,
  Packaging Materials, Design, Competitor Analysis, BOM, Legal) render
  their internal tabs as folder tabs at the top of the form pane, exactly
  the way users see them when filling the form.

  Usage:
    include('_readonly_view', { productRequest, ref, attachments, designAttachments, legalAttachments })
*/
var pr  = productRequest;
var mk  = pr.marketing || {};
var br  = pr.brand     || {};
var rnd = pr.rnd       || {};
var fc  = pr.forecast  || {};
var rp  = pr.referenceProduct || {};
var prodPlan = (pr.production && pr.production.plan)      || {};
var prodPkg  = (pr.production && pr.production.packaging) || {};
var prodFrm  = (pr.production && pr.production.formula)   || {};
var cmp      = pr.competitor || {};
var atts     = (typeof attachments !== 'undefined' && attachments) ? attachments : [];
var pkm      = pr.packaging || {};
var pkmMat   = pkm.materials      || {};
var pkmComps = pkm.components     || [];
var pkmInco  = pkm.incoterms      || [];
var pkmCost  = pkm.cost_updated   || {};
var pkmVol   = pkm.volume_updated || {};
var pkmComp  = pkm.comparisons    || [];
var dsn      = pr.design || {};
var dsnAtts  = (typeof designAttachments !== 'undefined' && designAttachments) ? designAttachments : [];
var dsnByCat = dsnAtts.reduce(function (m, a) { (m[a.category] = m[a.category] || []).push(a); return m; }, {});
var bomPkgRO = pr.bomPackaging || [];
var bomFrmRO = pr.bomFormula   || [];
var legalRO  = pr.legal || {};
var legalAtts = (typeof legalAttachments !== 'undefined' && legalAttachments) ? legalAttachments : [];

function show(v, fallback) {
  if (v === null || v === undefined || v === '') return fallback || '—';
  return v;
}
function fmt(n) {
  if (n === null || n === undefined || n === '') return '—';
  if (typeof n === 'number') return n.toLocaleString();
  return n;
}

// Determine which forms exist on this request, in workflow order. The left
// nav only shows forms that actually have data.
var hasStage2     = !!(mk.market || br.brand || rnd.material_type || fc.total_y1 != null);
var hasProduction = !!(pr.production_completed_at || prodPlan.launch_start_date);
var hasPackaging  = !!(pr.packaging_completed_at  || pkmMat.material_type);
var hasDesign     = !!(pr.design_completed_at     || (dsn.agency && dsn.agency.name) || dsnAtts.length);
var hasCompetitor = !!(pr.competitor_completed_at || cmp.market_type);
var hasBom        = !!(pr.bom_completed_at || bomPkgRO.length || bomFrmRO.length);
var hasLegal      = !!(pr.legal_completed_at || (legalRO.certifications || []).length || (legalRO.registrations || []).length);
var hasMdm        = !!pr.mdm_completed_at;

var formList = [
  { id:'initiate',  label:'Initiate',                show:true },
  { id:'stage2',    label:'Marketing & R&D Details', show:hasStage2 },
  { id:'production',label:'Production',              show:hasProduction },
  { id:'packaging', label:'Packaging Materials',     show:hasPackaging },
  { id:'design',    label:'Design',                  show:hasDesign },
  { id:'competitor',label:'Competitor Analysis',     show:hasCompetitor },
  { id:'bom',       label:'BOM Selection',           show:hasBom },
  { id:'legal',     label:'Legal Task',              show:hasLegal },
  { id:'mdm',       label:'MDM Material Review',     show:hasMdm },
].filter(function (f) { return f.show; });
%>

<style>
  /* ---------- horizontal "Submitted forms" pill bar ---------- */
  .rv-tabs-bar {
    display:flex; flex-wrap:wrap; gap:6px; align-items:center;
    background:white; border:1px solid #e2e8f0; border-radius:10px;
    padding:10px 12px; margin-bottom:14px;
    box-shadow:0 1px 2px rgba(0,0,0,.04);
  }
  .rv-tabs-label {
    font-size:10px; text-transform:uppercase; letter-spacing:.06em;
    color:#94a3b8; font-weight:700; padding-right:6px;
  }
  .rv-tabs-bar button {
    display:inline-flex; align-items:center; gap:6px;
    padding:7px 12px;
    border:1px solid #e2e8f0; border-radius:7px;
    background:white; color:#475569;
    font-size:12.5px; font-weight:500; cursor:pointer;
    transition: background-color .12s ease, color .12s ease, border-color .12s ease;
  }
  .rv-tabs-bar button:hover { background:#f1f5f9; color:#0f172a; }
  .rv-tabs-bar button.active { background:#1e3a8a; border-color:#1e3a8a; color:white; font-weight:600; }
  .rv-tabs-bar button .rv-num {
    display:inline-flex; align-items:center; justify-content:center;
    min-width:18px; height:18px; padding:0 5px; border-radius:5px;
    background:#e2e8f0; color:#475569; font-size:10.5px; font-weight:700;
  }
  .rv-tabs-bar button.active .rv-num { background:rgba(255,255,255,0.25); color:white; }

  /* ---------- form content area (full width below the pill bar) ---------- */
  .rv-content { width:100%; margin-bottom:18px; }
  .rv-form    { display:none; }
  .rv-form.active { display:block; }

  /* ---------- folder tabs (per form) ---------- */
  .rv-folder-nav {
    display:flex; flex-wrap:wrap; gap:2px; padding:0 6px;
    margin:0 0 -1px 0; position:relative; z-index:2;
  }
  .rv-folder-nav button {
    display:inline-flex; align-items:center; gap:8px;
    padding:8px 16px; border:1px solid #e5e7eb;
    border-radius:8px 8px 0 0;
    background:#f3f4f6; color:#4b5563;
    font-size:13px; cursor:pointer; white-space:nowrap;
  }
  .rv-folder-nav button:hover { background:#e5e7eb; }
  .rv-folder-nav button.active {
    background:white; color:#111827; font-weight:600;
    border-bottom-color:white; z-index:3;
  }
  .rv-folder-pane { display:none; }
  .rv-folder-pane.active { display:block; }

  /* ---------- card styling — applied to each pane ---------- */
  .rv-card {
    background:white; border:1px solid #e5e7eb;
    border-radius:0 8px 8px 8px;
    padding:18px 22px; box-shadow:0 1px 2px rgba(0,0,0,.04);
    position:relative; z-index:1;
  }
  /* When a form has only one pane, the top corners need rounding too. */
  .rv-card.rv-card-flat { border-radius:8px; }
  .rv-card h2 { font-size:16px; font-weight:600; color:#111827; margin:0 0 10px; padding-bottom:6px; border-bottom:1px solid #e5e7eb; display:flex; gap:.5rem; align-items:center; flex-wrap:wrap; }
  .rv-card h3 { font-size:12.5px; font-weight:700; color:#374151; margin:14px 0 6px; text-transform:uppercase; letter-spacing:.05em; }

  /* ---------- shared row / table ---------- */
  .rv-grid { display:grid; grid-template-columns:repeat(2, minmax(0,1fr)); gap:8px 28px; font-size:13px; }
  .rv-grid.cols-3 { grid-template-columns:repeat(3, minmax(0,1fr)); }
  .rv-grid.cols-4 { grid-template-columns:repeat(4, minmax(0,1fr)); }
  .rv-row { display:flex; flex-direction:column; gap:1px; padding:4px 0; border-bottom:1px dashed #f3f4f6; }
  .rv-row.full { grid-column:1 / -1; }
  .rv-row .rv-label { font-size:11px; color:#6b7280; text-transform:uppercase; letter-spacing:.04em; }
  .rv-row .rv-value { font-size:14px; color:#111827; white-space:pre-wrap; }
  .rv-pill { display:inline-block; padding:.1rem .55rem; border-radius:9999px; background:#eef2ff; color:#3730a3; font-size:11px; font-weight:600; }
  .rv-table { width:100%; border-collapse:collapse; font-size:12px; margin-top:6px; }
  .rv-table th, .rv-table td { padding:6px 8px; border-bottom:1px solid #e5e7eb; text-align:right; }
  .rv-table th { background:#f9fafb; color:#374151; text-align:center; font-weight:600; }
  .rv-table th:first-child, .rv-table td:first-child { text-align:left; }
  .rv-table .rv-total { background:#eff6ff; font-weight:600; color:#1e3a8a; }
  .rv-banner { background:#eff6ff; border:1px solid #bfdbfe; padding:.65rem .9rem; border-radius:.5rem; font-size:13px; color:#1e3a8a; margin-bottom:.6rem; }
</style>

<!-- ===================== TOP NAV BAR ===================== -->
<nav class="rv-tabs-bar" data-rv-leftnav>
  <span class="rv-tabs-label">Submitted forms</span>
  <% formList.forEach(function (f, i) { %>
    <button type="button" data-rv-form-btn="<%= f.id %>" class="<%= i === 0 ? 'active' : '' %>">
      <span class="rv-num"><%= i + 1 %></span>
      <span><%= f.label %></span>
    </button>
  <% }); %>
</nav>

<!-- ===================== FORM CONTENT (full width) ===================== -->
<div class="rv-content">

    <!-- ============== Initiate (no internal tabs) ============== -->
    <section class="rv-form active" data-form="initiate">
      <div class="rv-card rv-card-flat">
        <h2>Initiate</h2>
        <div class="rv-grid">
          <div class="rv-row"><span class="rv-label">Request type</span><span class="rv-value"><%= pr.request_type ? pr.request_type.replace(/_/g,' ') : '—' %></span></div>
          <div class="rv-row"><span class="rv-label">Request date</span><span class="rv-value"><%= show(pr.request_date) %></span></div>
          <div class="rv-row"><span class="rv-label">Requestor</span><span class="rv-value"><%= show(pr.requestor_name) %><% if (pr.requestor_email) { %> &lt;<%= pr.requestor_email %>&gt;<% } %></span></div>
          <div class="rv-row"><span class="rv-label">Product name</span><span class="rv-value"><%= show(pr.product_name) %></span></div>
          <% if (rp.sku) { %>
            <div class="rv-row full">
              <span class="rv-label">Reference product</span>
              <span class="rv-value">
                <span class="rv-pill"><%= rp.sku %></span> <%= rp.name %>
                <% if (rp.brand) { %> · <%= rp.brand %><% } %>
                <% if (rp.bom && rp.bom.length) { %> · <%= rp.bom.length %>-line BOM available for reuse<% } %>
              </span>
            </div>
          <% } %>
        </div>
      </div>
    </section>

    <!-- ============== Stage 2 — 4 internal folder tabs ============== -->
    <% if (hasStage2) { %>
      <section class="rv-form" data-form="stage2">
        <nav class="rv-folder-nav">
          <button class="active" data-folder-group="stage2" data-folder-tab="stage2-mk">Marketing</button>
          <button                data-folder-group="stage2" data-folder-tab="stage2-br">Brand</button>
          <button                data-folder-group="stage2" data-folder-tab="stage2-rd">R&amp;D</button>
          <button                data-folder-group="stage2" data-folder-tab="stage2-fc">Forecast</button>
        </nav>

        <div class="rv-folder-pane active" data-folder-pane-group="stage2" data-folder-pane="stage2-mk">
          <div class="rv-card">
            <h2>Marketing</h2>
            <div class="rv-grid">
              <div class="rv-row"><span class="rv-label">Target market</span><span class="rv-value">
                <% var marketRow = (ref && ref.PRODUCT_MARKETS || []).find(function (m) { return m.code === mk.market; }); %>
                <%= marketRow ? (marketRow.name + ' (' + marketRow.currency + ')') : show(mk.market) %>
              </span></div>
              <div class="rv-row"><span class="rv-label">Packaging / Formula</span><span class="rv-value">
                Packaging: <strong><%= show(mk.packaging_status) %></strong>
                · Formula: <strong><%= show(mk.formula_status) %></strong>
              </span></div>
              <div class="rv-row full"><span class="rv-label">Rationale</span><span class="rv-value"><%= show(mk.rationale) %></span></div>
              <div class="rv-row full"><span class="rv-label">Competitor &amp; Market Positioning</span><span class="rv-value"><%= show(mk.positioning) %></span></div>
              <div class="rv-row full"><span class="rv-label">Launch Plan</span><span class="rv-value"><%= show(mk.launch_plan) %></span></div>
            </div>
          </div>
        </div>

        <div class="rv-folder-pane" data-folder-pane-group="stage2" data-folder-pane="stage2-br">
          <div class="rv-card">
            <h2>Brand</h2>
            <div class="rv-grid cols-3">
              <div class="rv-row"><span class="rv-label">Category Grouper</span><span class="rv-value"><%= show(br.category_grouper) %></span></div>
              <div class="rv-row"><span class="rv-label">Category</span><span class="rv-value"><%= show(br.category) %></span></div>
              <div class="rv-row"><span class="rv-label">Family Brand</span><span class="rv-value"><%= show(br.family_brand) %></span></div>
              <div class="rv-row"><span class="rv-label">Brand</span><span class="rv-value"><%= show(br.brand) %></span></div>
              <div class="rv-row"><span class="rv-label">Sub Brand</span><span class="rv-value"><%= show(br.sub_brand) %></span></div>
            </div>
          </div>
        </div>

        <div class="rv-folder-pane" data-folder-pane-group="stage2" data-folder-pane="stage2-rd">
          <div class="rv-card">
            <h2>R&amp;D</h2>
            <h3>SAP classification</h3>
            <div class="rv-grid">
              <div class="rv-row"><span class="rv-label">Material Type (SAP)</span><span class="rv-value"><%= show(rnd.material_type) %></span></div>
              <div class="rv-row"><span class="rv-label">Base UoM</span><span class="rv-value"><%= show(rnd.base_uom) %></span></div>
            </div>
            <h3>Dimensions</h3>
            <div class="rv-grid cols-4">
              <div class="rv-row"><span class="rv-label">Length</span><span class="rv-value"><%= fmt(rnd.length) %> <%= rnd.dim_unit || '' %></span></div>
              <div class="rv-row"><span class="rv-label">Width</span><span class="rv-value"><%= fmt(rnd.width) %> <%= rnd.dim_unit || '' %></span></div>
              <div class="rv-row"><span class="rv-label">Height</span><span class="rv-value"><%= fmt(rnd.height) %> <%= rnd.dim_unit || '' %></span></div>
              <div class="rv-row"><span class="rv-label">Volume</span><span class="rv-value"><%= fmt(rnd.volume) %> <%= rnd.volume_unit || '' %></span></div>
              <div class="rv-row"><span class="rv-label">Net Weight</span><span class="rv-value"><%= fmt(rnd.net_weight) %> <%= rnd.weight_unit || '' %></span></div>
              <div class="rv-row"><span class="rv-label">Gross Weight</span><span class="rv-value"><%= fmt(rnd.gross_weight) %> <%= rnd.weight_unit || '' %></span></div>
            </div>
            <h3>Pricing</h3>
            <div class="rv-grid cols-3">
              <div class="rv-row"><span class="rv-label">Manufacturing Price (USD)</span><span class="rv-value"><%= fmt(rnd.mfg_price) %> USD</span></div>
              <div class="rv-row"><span class="rv-label">Manufacturing Price (Local)</span><span class="rv-value"><%= fmt(rnd.mfg_price_local) %> <%= rnd.retail_price_local_ccy || '' %></span></div>
              <div class="rv-row"></div>
              <div class="rv-row"><span class="rv-label">Retail Price (USD)</span><span class="rv-value"><%= fmt(rnd.retail_price_usd) %> USD</span></div>
              <div class="rv-row"><span class="rv-label">Retail Price (Local)</span><span class="rv-value"><%= fmt(rnd.retail_price_local) %> <%= rnd.retail_price_local_ccy || '' %></span></div>
              <% if (rnd.fx_rate) { %>
                <div class="rv-row full"><span class="rv-label">FX Rate captured at submit</span>
                  <span class="rv-value">1 USD = <strong><%= rnd.fx_rate %></strong> <%= rnd.retail_price_local_ccy || '' %>
                    · <%= rnd.fx_as_of || '' %>
                    <% if (rnd.fx_source) { %> · <em><%= rnd.fx_source %></em><% } %>
                  </span>
                </div>
              <% } %>
            </div>
            <h3>Contract</h3>
            <div class="rv-grid">
              <div class="rv-row"><span class="rv-label">Status</span><span class="rv-value"><%= show(rnd.contract_status && rnd.contract_status.replace(/_/g,' ')) %></span></div>
              <div class="rv-row"><span class="rv-label">Existing supplier?</span><span class="rv-value"><%= show(rnd.existing_supplier) %></span></div>
              <div class="rv-row full"><span class="rv-label">Supplier name</span><span class="rv-value"><%= show(rnd.contract_supplier) %></span></div>
            </div>
          </div>
        </div>

        <div class="rv-folder-pane" data-folder-pane-group="stage2" data-folder-pane="stage2-fc">
          <div class="rv-card">
            <h2>Forecast</h2>
            <table class="rv-table">
              <thead><tr><th>Period</th>
                <% ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'].forEach(function (m) { %><th><%= m %></th><% }); %>
                <th>Total</th></tr>
              </thead>
              <tbody><tr>
                <td><strong>Year 1</strong></td>
                <% ['jan','feb','mar','apr','may','jun','jul','aug','sep','oct','nov','dec'].forEach(function (m) { %>
                  <td><%= fmt(fc['y1_' + m]) %></td>
                <% }); %>
                <td class="rv-total"><%= fmt(fc.total_y1) %></td>
              </tr></tbody>
            </table>
            <div class="rv-grid cols-4" style="margin-top:10px;">
              <div class="rv-row"><span class="rv-label">Year 2</span><span class="rv-value"><%= fmt(fc.y2) %></span></div>
              <div class="rv-row"><span class="rv-label">Year 3</span><span class="rv-value"><%= fmt(fc.y3) %></span></div>
              <div class="rv-row"><span class="rv-label">Year 4</span><span class="rv-value"><%= fmt(fc.y4) %></span></div>
              <div class="rv-row"><span class="rv-label">Year 5</span><span class="rv-value"><%= fmt(fc.y5) %></span></div>
              <div class="rv-row full"><span class="rv-label">5-Year Total</span><span class="rv-value"><strong style="font-size:16px;color:#1e3a8a;"><%= fmt(fc.total_y5) %></strong></span></div>
            </div>
          </div>
        </div>
      </section>
    <% } %>

    <!-- ============== Production — 3 internal folder tabs ============== -->
    <% if (hasProduction) { %>
      <section class="rv-form" data-form="production">
        <nav class="rv-folder-nav">
          <button class="active" data-folder-group="production" data-folder-tab="prd-plan">Production Plan</button>
          <button                data-folder-group="production" data-folder-tab="prd-pkg">Packaging</button>
          <button                data-folder-group="production" data-folder-tab="prd-frm">Formula</button>
          <button                data-folder-group="production" data-folder-tab="prd-legal">Legal Certificates</button>
        </nav>
        <div class="rv-folder-pane active" data-folder-pane-group="production" data-folder-pane="prd-plan">
          <div class="rv-card">
            <h2>Production Plan
              <% if (pr.production_completed_at) { %><span class="rv-pill" style="background:#dcfce7;color:#166534;">Submitted <%= pr.production_completed_at %></span><% } else { %><span class="rv-pill" style="background:#fef3c7;color:#92400e;">In progress</span><% } %>
            </h2>
            <div class="rv-grid cols-3">
              <div class="rv-row"><span class="rv-label">Launch start</span><span class="rv-value"><%= show(prodPlan.launch_start_date) %></span></div>
              <div class="rv-row"><span class="rv-label">Launch target</span><span class="rv-value"><%= show(prodPlan.launch_target_date) %></span></div>
              <div class="rv-row"><span class="rv-label">Lead time</span><span class="rv-value"><%= prodPlan.lead_time_weeks != null ? (prodPlan.lead_time_weeks + ' weeks') : '—' %></span></div>
              <div class="rv-row"><span class="rv-label">Launch type</span><span class="rv-value"><%= show(prodPlan.launch_type && prodPlan.launch_type.replace(/_/g,' ')) %></span></div>
            </div>
            <% if (prodPlan.launch_type === 'LIMITED_TIME') { %>
              <h3>Limited-time campaign window</h3>
              <div class="rv-grid cols-3">
                <div class="rv-row"><span class="rv-label">Start launch date</span><span class="rv-value"><%= show(prodPlan.limited_start_date) %></span></div>
                <div class="rv-row"><span class="rv-label">End launch date</span><span class="rv-value"><%= show(prodPlan.limited_end_date) %></span></div>
                <div class="rv-row"><span class="rv-label">Release time</span><span class="rv-value"><%= prodPlan.release_weeks != null ? (prodPlan.release_weeks + ' weeks') : '—' %></span></div>
              </div>
            <% } %>
          </div>
        </div>
        <div class="rv-folder-pane" data-folder-pane-group="production" data-folder-pane="prd-pkg">
          <div class="rv-card">
            <h2>Packaging</h2>
            <div class="rv-grid cols-3">
              <div class="rv-row"><span class="rv-label">Origin</span><span class="rv-value"><%= show(prodPkg.origin) %></span></div>
              <div class="rv-row"><span class="rv-label">Region / Country</span><span class="rv-value"><%= show(prodPkg.region) %><% if (prodPkg.country) { %> · <%= prodPkg.country %><% } %></span></div>
              <div class="rv-row full"><span class="rv-label">Site</span><span class="rv-value"><%= show(prodPkg.site) %></span></div>
            </div>
          </div>
        </div>
        <div class="rv-folder-pane" data-folder-pane-group="production" data-folder-pane="prd-frm">
          <div class="rv-card">
            <h2>Formula</h2>
            <div class="rv-grid cols-3">
              <div class="rv-row"><span class="rv-label">Origin</span><span class="rv-value"><%= show(prodFrm.origin) %></span></div>
              <div class="rv-row"><span class="rv-label">Category</span><span class="rv-value"><%= show(prodFrm.category) %></span></div>
              <div class="rv-row"><span class="rv-label">Class</span><span class="rv-value"><%= show(prodFrm.class) %></span></div>
              <div class="rv-row"><span class="rv-label">Brand</span><span class="rv-value"><%= show(prodFrm.brand_tier) %></span></div>
              <div class="rv-row"><span class="rv-label">Formula type</span><span class="rv-value"><%= show(prodFrm.formula_type) %></span></div>
              <div class="rv-row"><span class="rv-label">Flavor</span><span class="rv-value"><%= show(prodFrm.flavor) %></span></div>
              <div class="rv-row"><span class="rv-label">Color</span><span class="rv-value"><%= show(prodFrm.color) %></span></div>
              <div class="rv-row"><span class="rv-label">Appearance</span><span class="rv-value"><%= show(prodFrm.appearance) %></span></div>
              <div class="rv-row"><span class="rv-label">Cold storage</span><span class="rv-value"><%= show(prodFrm.cold_storage) %></span></div>
              <div class="rv-row"><span class="rv-label">Carbonated</span><span class="rv-value"><%= show(prodFrm.carbonated) %></span></div>
            </div>
          </div>
        </div>
        <div class="rv-folder-pane" data-folder-pane-group="production" data-folder-pane="prd-legal">
          <div class="rv-card">
            <h2>Legal Certificates</h2>
            <% if (prodFrm.certificates && prodFrm.certificates.length) { %>
              <ul style="font-size:13px; padding-left:18px; list-style:disc; color:#374151;">
                <% prodFrm.certificates.forEach(function (c) { %>
                  <li><strong><%= c.code %></strong>
                    <% if (c.comment) { %> — <em><%= c.comment %></em><% } %>
                    <% var fileMatches = atts.filter(function (a) { return a.certificate_type === c.code; });
                       fileMatches.forEach(function (f) { %>
                       · <a href="/products/workflow/<%= pr.id %>/attachments/<%= f.id %>" class="text-blue-600 hover:underline" target="_blank"><%= f.original_name %></a>
                    <% }); %>
                  </li>
                <% }); %>
              </ul>
            <% } else { %>
              <p style="color:#94a3b8;font-size:13px;">No legal certificates submitted.</p>
            <% } %>
