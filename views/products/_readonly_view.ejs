<%
/*
  views/products/_readonly_view.ejs
  ---------------------------------------------------------------------------
  Renders every Stage 1 + Stage 2 field that the requestor populated, as
  view-only sections that mirror the layout of new_details.ejs (4 tabs:
  Marketing, Brand, R&D, Forecast — plus an "Initiate" header). Used by
  every approval view.

  Usage:
    include('_readonly_view', { productRequest, ref })
*/
var pr  = productRequest;
var mk  = pr.marketing || {};
var br  = pr.brand     || {};
var rnd = pr.rnd       || {};
var fc  = pr.forecast  || {};
var rp  = pr.referenceProduct || {};

function show(v, fallback) {
  if (v === null || v === undefined || v === '' ) return fallback || '—';
  return v;
}
function fmt(n) {
  if (n === null || n === undefined || n === '') return '—';
  if (typeof n === 'number') return n.toLocaleString();
  return n;
}
%>

<style>
  .ro-card { background:#fff; border:1px solid #e5e7eb; border-radius:8px; padding:18px 22px; box-shadow:0 1px 2px rgba(0,0,0,.04); margin-bottom:14px; }
  .ro-card h2 { font-size:16px; font-weight:600; color:#111827; margin:0 0 10px; padding-bottom:6px; border-bottom:1px solid #e5e7eb; }
  .ro-card h3 { font-size:13px; font-weight:600; color:#374151; margin:14px 0 6px; text-transform:uppercase; letter-spacing:.04em; }
  .ro-grid { display:grid; grid-template-columns:repeat(2, minmax(0,1fr)); gap:8px 28px; font-size:13px; }
  .ro-grid.cols-3 { grid-template-columns:repeat(3, minmax(0,1fr)); }
  .ro-grid.cols-4 { grid-template-columns:repeat(4, minmax(0,1fr)); }
  .ro-row { display:flex; flex-direction:column; gap:1px; padding:4px 0; border-bottom:1px dashed #f3f4f6; }
  .ro-row.full { grid-column:1 / -1; }
  .ro-row .ro-label { font-size:11px; color:#6b7280; text-transform:uppercase; letter-spacing:.04em; }
  .ro-row .ro-value { font-size:14px; color:#111827; white-space:pre-wrap; }
  .ro-pill { display:inline-block; padding:.1rem .55rem; border-radius:9999px; background:#eef2ff; color:#3730a3; font-size:11px; font-weight:600; }
  .ro-fc-table { width:100%; border-collapse:collapse; font-size:12px; }
  .ro-fc-table th, .ro-fc-table td { padding:6px 8px; border-bottom:1px solid #e5e7eb; text-align:right; }
  .ro-fc-table th { background:#f9fafb; color:#374151; text-align:center; font-weight:600; }
  .ro-fc-table th:first-child, .ro-fc-table td:first-child { text-align:left; }
  .ro-fc-table .ro-total { background:#eff6ff; font-weight:600; color:#1e3a8a; }
</style>

<!-- Initiate / project header -->
<div class="ro-card">
  <h2>Initiate</h2>
  <div class="ro-grid">
    <div class="ro-row">
      <span class="ro-label">Request type</span>
      <span class="ro-value"><%= pr.request_type ? pr.request_type.replace(/_/g,' ') : '—' %></span>
    </div>
    <div class="ro-row">
      <span class="ro-label">Request date</span>
      <span class="ro-value"><%= show(pr.request_date) %></span>
    </div>
    <div class="ro-row">
      <span class="ro-label">Requestor</span>
      <span class="ro-value"><%= show(pr.requestor_name) %><% if (pr.requestor_email) { %> &lt;<%= pr.requestor_email %>&gt;<% } %></span>
    </div>
    <div class="ro-row">
      <span class="ro-label">Product name</span>
      <span class="ro-value"><%= show(pr.product_name) %></span>
    </div>
    <% if (rp.sku) { %>
      <div class="ro-row full">
        <span class="ro-label">Reference product</span>
        <span class="ro-value">
          <span class="ro-pill"><%= rp.sku %></span> <%= rp.name %>
          <% if (rp.brand) { %> · <%= rp.brand %><% } %>
          <% if (rp.bom && rp.bom.length) { %>
            · <%= rp.bom.length %>-line BOM available for reuse
          <% } %>
        </span>
      </div>
    <% } %>
  </div>
</div>

<!-- 1) Marketing -->
<div class="ro-card">
  <h2>1 · Marketing</h2>
  <div class="ro-grid">
    <div class="ro-row">
      <span class="ro-label">Target market</span>
      <span class="ro-value">
        <% var marketRow = (ref && ref.PRODUCT_MARKETS || []).find(function (m) { return m.code === mk.market; }); %>
        <%= marketRow ? (marketRow.name + ' (' + marketRow.currency + ')') : show(mk.market) %>
      </span>
    </div>
    <div class="ro-row">
      <span class="ro-label">Packaging / Formula</span>
      <span class="ro-value">
        Packaging: <strong><%= show(mk.packaging_status) %></strong>
        · Formula: <strong><%= show(mk.formula_status) %></strong>
      </span>
    </div>
    <div class="ro-row full">
      <span class="ro-label">Rationale</span>
      <span class="ro-value"><%= show(mk.rationale) %></span>
    </div>
    <div class="ro-row full">
      <span class="ro-label">Competitor &amp; Market Positioning</span>
      <span class="ro-value"><%= show(mk.positioning) %></span>
    </div>
    <div class="ro-row full">
      <span class="ro-label">Launch Plan</span>
      <span class="ro-value"><%= show(mk.launch_plan) %></span>
    </div>
  </div>
</div>

<!-- 2) Brand -->
<div class="ro-card">
  <h2>2 · Brand</h2>
  <div class="ro-grid cols-3">
    <div class="ro-row"><span class="ro-label">Category Grouper</span><span class="ro-value"><%= show(br.category_grouper) %></span></div>
    <div class="ro-row"><span class="ro-label">Category</span><span class="ro-value"><%= show(br.category) %></span></div>
    <div class="ro-row"><span class="ro-label">Family Brand</span><span class="ro-value"><%= show(br.family_brand) %></span></div>
    <div class="ro-row"><span class="ro-label">Brand</span><span class="ro-value"><%= show(br.brand) %></span></div>
    <div class="ro-row"><span class="ro-label">Sub Brand</span><span class="ro-value"><%= show(br.sub_brand) %></span></div>
  </div>
</div>

<!-- 3) R&D -->
<div class="ro-card">
  <h2>3 · R&amp;D</h2>
  <h3>SAP classification</h3>
  <div class="ro-grid">
    <div class="ro-row"><span class="ro-label">Material Type (SAP)</span><span class="ro-value"><%= show(rnd.material_type) %></span></div>
    <div class="ro-row"><span class="ro-label">Base UoM</span><span class="ro-value"><%= show(rnd.base_uom) %></span></div>
  </div>

  <h3>Dimensions</h3>
  <div class="ro-grid cols-4">
    <div class="ro-row"><span class="ro-label">Length</span><span class="ro-value"><%= fmt(rnd.length) %> <%= rnd.dim_unit || '' %></span></div>
    <div class="ro-row"><span class="ro-label">Width</span><span class="ro-value"><%= fmt(rnd.width) %> <%= rnd.dim_unit || '' %></span></div>
    <div class="ro-row"><span class="ro-label">Height</span><span class="ro-value"><%= fmt(rnd.height) %> <%= rnd.dim_unit || '' %></span></div>
    <div class="ro-row"><span class="ro-label">Volume</span><span class="ro-value"><%= fmt(rnd.volume) %> <%= rnd.volume_unit || '' %></span></div>
    <div class="ro-row"><span class="ro-label">Net Weight</span><span class="ro-value"><%= fmt(rnd.net_weight) %> <%= rnd.weight_unit || '' %></span></div>
    <div class="ro-row"><span class="ro-label">Gross Weight</span><span class="ro-value"><%= fmt(rnd.gross_weight) %> <%= rnd.weight_unit || '' %></span></div>
  </div>

  <h3>Pricing</h3>
  <div class="ro-grid cols-3">
    <div class="ro-row"><span class="ro-label">Manufacturing Price</span><span class="ro-value"><%= fmt(rnd.mfg_price) %> <%= rnd.mfg_price_ccy || '' %></span></div>
    <div class="ro-row"><span class="ro-label">Retail Price (USD)</span><span class="ro-value"><%= fmt(rnd.retail_price_usd) %> USD</span></div>
    <div class="ro-row"><span class="ro-label">Retail Price (Local)</span><span class="ro-value"><%= fmt(rnd.retail_price_local) %> <%= rnd.retail_price_local_ccy || '' %></span></div>
    <% if (rnd.fx_rate) { %>
      <div class="ro-row full">
        <span class="ro-label">FX Rate captured at submit</span>
        <span class="ro-value">1 USD = <strong><%= rnd.fx_rate %></strong> <%= rnd.retail_price_local_ccy || '' %>
          · <%= rnd.fx_as_of || '' %>
          <% if (rnd.fx_source) { %> · <em><%= rnd.fx_source %></em><% } %>
        </span>
      </div>
    <% } %>
  </div>

  <h3>Contract</h3>
  <div class="ro-grid">
    <div class="ro-row"><span class="ro-label">Status</span><span class="ro-value"><%= show(rnd.contract_status && rnd.contract_status.replace(/_/g,' ')) %></span></div>
    <div class="ro-row"><span class="ro-label">Supplier</span><span class="ro-value"><%= show(rnd.contract_supplier) %></span></div>
  </div>
</div>

<!-- 4) Forecast -->
<div class="ro-card">
  <h2>4 · Forecast</h2>
  <table class="ro-fc-table">
    <thead>
      <tr>
        <th>Period</th>
        <% ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'].forEach(function (m) { %><th><%= m %></th><% }); %>
        <th>Total</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td><strong>Year 1</strong></td>
        <% ['jan','feb','mar','apr','may','jun','jul','aug','sep','oct','nov','dec'].forEach(function (m) { %>
          <td><%= fmt(fc['y1_' + m]) %></td>
        <% }); %>
        <td class="ro-total"><%= fmt(fc.total_y1) %></td>
      </tr>
    </tbody>
  </table>
  <div class="ro-grid cols-4" style="margin-top:10px;">
    <div class="ro-row"><span class="ro-label">Year 2</span><span class="ro-value"><%= fmt(fc.y2) %></span></div>
    <div class="ro-row"><span class="ro-label">Year 3</span><span class="ro-value"><%= fmt(fc.y3) %></span></div>
    <div class="ro-row"><span class="ro-label">Year 4</span><span class="ro-value"><%= fmt(fc.y4) %></span></div>
    <div class="ro-row"><span class="ro-label">Year 5</span><span class="ro-value"><%= fmt(fc.y5) %></span></div>
    <div class="ro-row full"><span class="ro-label">5-Year Total</span><span class="ro-value"><strong style="font-size:16px;color:#1e3a8a;"><%= fmt(fc.total_y5) %></strong></span></div>
  </div>
</div>
