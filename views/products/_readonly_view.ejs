    <!-- ============== BOM Selection — 2 internal folder tabs ============== -->
    <% if (hasBom) { %>
      <%
        function bomTable(rows) {
          var out = '';
          if (!rows.length) return '<p style="color:#94a3b8;font-size:13px;">No components.</p>';
          out += '<table class="rv-table"><thead><tr>'
              + '<th style="text-align:left;">Source</th>'
              + '<th style="text-align:left;">Material #</th>'
              + '<th style="text-align:left;">Description</th>'
              + '<th style="text-align:left;">Category</th>'
              + '<th style="text-align:left;">Brand</th>'
              + '<th style="text-align:left;">Mat. Group</th>'
              + '<th>Type</th><th>UoM</th><th>Div.</th><th>Volume</th><th>Quantity</th>'
              + '</tr></thead><tbody>';
          rows.forEach(function (r) {
            var pillBg    = r.source === 'NEW' ? '#fde68a' : (r.source === 'MASTER' ? '#dbeafe' : '#bbf7d0');
            var pillFg    = r.source === 'NEW' ? '#92400e' : (r.source === 'MASTER' ? '#1e40af' : '#166534');
            out += '<tr>'
                + '<td style="text-align:left;"><span class="rv-pill" style="background:'+pillBg+';color:'+pillFg+';">'+show(r.source)+'</span></td>'
                + '<td style="text-align:left;font-family:ui-monospace,monospace;">'+show(r.material_number)+'</td>'
                + '<td style="text-align:left;">'+show(r.material_description)+'</td>'
                + '<td style="text-align:left;">'+show(r.category_name)+'</td>'
                + '<td style="text-align:left;">'+show(r.brand)+'</td>'
                + '<td style="text-align:left;">'+show(r.material_group)+'</td>'
                + '<td>'+show(r.material_type)+'</td>'
                + '<td>'+show(r.base_uom)+'</td>'
                + '<td>'+show(r.division)+'</td>'
                + '<td>'+fmt(r.volume)+'</td>'
                + '<td>'+fmt(r.quantity)+'</td>'
                + '</tr>';
            if (r.source === 'NEW' && r.vendor) {
              out += '<tr><td colspan="11" style="text-align:left;background:#fffbeb;font-size:11px;color:#92400e;padding:4px 10px;">'
                  + 'Vendor: <strong>'+show(r.vendor.type)+'</strong>';
              if (r.vendor.type === 'EXISTING') {
                out += ' · code '+show(r.vendor.vendor_code);
              } else {
                out += ' · '+show(r.vendor.name);
                if (r.vendor.contact) out += ' · '+r.vendor.contact;
                if (r.vendor.email)   out += ' · '+r.vendor.email;
                if (r.vendor.phone)   out += ' · '+r.vendor.phone;
              }
              out += '</td></tr>';
            }
          });
          out += '</tbody></table>';
          return out;
        }
      %>
      <section class="rv-form" data-form="bom">
        <nav class="rv-folder-nav">
          <button class="active" data-folder-group="bom" data-folder-tab="bom-pkg">Packaging BOM</button>
          <button                data-folder-group="bom" data-folder-tab="bom-frm">Formula BOM</button>
        </nav>
        <div class="rv-folder-pane active" data-folder-pane-group="bom" data-folder-pane="bom-pkg">
          <div class="rv-card">
            <h2>Packaging BOM (<%= bomPkgRO.length %>)
              <% if (pr.bom_completed_at) { %><span class="rv-pill" style="background:#dcfce7;color:#166534;">Submitted <%= pr.bom_completed_at %></span><% } else { %><span class="rv-pill" style="background:#fef3c7;color:#92400e;">In progress</span><% } %>
            </h2>
            <%- bomTable(bomPkgRO) %>
          </div>
        </div>
        <div class="rv-folder-pane" data-folder-pane-group="bom" data-folder-pane="bom-frm">
          <div class="rv-card">
            <h2>Formula BOM (<%= bomFrmRO.length %>)</h2>
            <%- bomTable(bomFrmRO) %>
          </div>
        </div>
      </section>
    <% } %>

