                      <td style="text-align:left;"><%= label %></td>
                      <td><%= show(c.status && c.status.replace(/_/g,' ')) %></td>
                      <td style="text-align:left;"><%= show(c.comment) %></td>
                      <td style="text-align:left;">
                        <% files.forEach(function (f) { %>
                          <a href="/products/workflow/<%= pr.id %>/attachments/<%= f.id %>" target="_blank" class="text-blue-600 hover:underline" style="margin-right:.5rem;">📎 <%= f.original_name %></a>
                        <% }); %>
                        <% if (!files.length) { %>—<% } %>
                      </td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            <% } else { %><p style="color:#94a3b8;font-size:13px;">No certifications recorded.</p><% } %>
          </div>
        </div>
        <div class="rv-folder-pane" data-folder-pane-group="legal" data-folder-pane="lg-reg">
          <div class="rv-card">
            <h2>Packaging Country Registration</h2>
            <% if ((legalRO.registrations || []).length) { %>
              <table class="rv-table">
                <thead><tr><th style="text-align:left;">Country</th><th>Status</th><th style="text-align:left;">Reg. #</th><th style="text-align:left;">Comment</th><th style="text-align:left;">File</th></tr></thead>
                <tbody>
                  <% legalRO.registrations.forEach(function (r) {
                      var match = (ref.PRODUCT_MARKETS || []).find(function (m) { return m.code === r.country; });
                      var label = match ? match.name : r.country;
                      var files = regAttsByCountry[r.country] || [];
                  %>
                    <tr>
                      <td style="text-align:left;"><%= label %></td>
                      <td><%= show(r.status && r.status.replace(/_/g,' ')) %></td>
                      <td style="text-align:left;font-family:ui-monospace,monospace;"><%= show(r.registration_number) %></td>
                      <td style="text-align:left;"><%= show(r.comment) %></td>
                      <td style="text-align:left;">
                        <% files.forEach(function (f) { %>
                          <a href="/products/workflow/<%= pr.id %>/attachments/<%= f.id %>" target="_blank" class="text-blue-600 hover:underline" style="margin-right:.5rem;">📎 <%= f.original_name %></a>
                        <% }); %>
                        <% if (!files.length) { %>—<% } %>
                      </td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            <% } else { %><p style="color:#94a3b8;font-size:13px;">No country registrations recorded.</p><% } %>
          </div>
        </div>
      </section>
    <% } %>

    <!-- ============== MDM annotation ============== -->
    <% if (hasMdm) { %>
      <section class="rv-form" data-form="mdm">
        <div class="rv-card rv-card-flat">
          <h2>MDM Material Review
            <span class="rv-pill" style="background:#dcfce7;color:#166534;">Submitted <%= pr.mdm_completed_at %></span>
          </h2>
          <p style="font-size:13px;color:#4b5563;">MDM has reviewed and refined the BOM components to align with SAP material-master conventions. The final values appear in the BOM Selection form.</p>
        </div>
      </section>
    <% } %>

  </div>

<script>
(function () {
  // Left-nav: switch which form is visible.
  document.querySelectorAll('[data-rv-form-btn]').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var target = btn.dataset.rvFormBtn;
      document.querySelectorAll('[data-rv-form-btn]').forEach(function (b) { b.classList.toggle('active', b === btn); });
      document.querySelectorAll('[data-form]').forEach(function (f) { f.classList.toggle('active', f.dataset.form === target); });
    });
  });

  // Per-form folder tabs: each group is independent.
  document.querySelectorAll('[data-folder-tab]').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var group = btn.dataset.folderGroup;
      var target = btn.dataset.folderTab;
      document.querySelectorAll('[data-folder-group="' + group + '"]').forEach(function (b) { b.classList.toggle('active', b === btn); });
      document.querySelectorAll('[data-folder-pane-group="' + group + '"]').forEach(function (p) { p.classList.toggle('active', p.dataset.folderPane === target); });
    });
  });
})();
</script>
