<%
/*
  views/products/_readonly_view.ejs
  ---------------------------------------------------------------------------
  Renders every Stage 1 + Stage 2 field that the requestor populated, as
  view-only sections that mirror the layout of new_details.ejs (4 tabs:
  Marketing, Brand, R&D, Forecast — plus an "Initiate" header). Used by
  every approval view.

  Usage:
    include('_readonly_view', { productRequest, ref })
*/
var pr  = productRequest;
var mk  = pr.marketing || {};
var br  = pr.brand     || {};
var rnd = pr.rnd       || {};
var fc  = pr.forecast  || {};
var rp  = pr.referenceProduct || {};
var prodPlan = (pr.production && pr.production.plan)      || {};
var prodPkg  = (pr.production && pr.production.packaging) || {};
var prodFrm  = (pr.production && pr.production.formula)   || {};
var cmp      = pr.competitor || {};
var atts     = (typeof attachments !== 'undefined' && attachments) ? attachments : [];
var pkm      = pr.packaging || {};
var pkmMat   = pkm.materials      || {};
var pkmComps = pkm.components     || [];
var pkmInco  = pkm.incoterms      || [];
var pkmCost  = pkm.cost_updated   || {};
var pkmVol   = pkm.volume_updated || {};
var pkmComp  = pkm.comparisons    || [];
var dsn      = pr.design || {};
var dsnAtts  = (typeof designAttachments !== 'undefined' && designAttachments) ? designAttachments : [];
var dsnByCat = dsnAtts.reduce(function (m, a) { (m[a.category] = m[a.category] || []).push(a); return m; }, {});

function show(v, fallback) {
  if (v === null || v === undefined || v === '' ) return fallback || '—';
  return v;
}
function fmt(n) {
  if (n === null || n === undefined || n === '') return '—';
  if (typeof n === 'number') return n.toLocaleString();
  return n;
}
%>

<style>
  .ro-card { background:#fff; border:1px solid #e5e7eb; border-radius:8px; padding:18px 22px; box-shadow:0 1px 2px rgba(0,0,0,.04); margin-bottom:14px; }
  .ro-card h2 { font-size:16px; font-weight:600; color:#111827; margin:0 0 10px; padding-bottom:6px; border-bottom:1px solid #e5e7eb; }
  .ro-card h3 { font-size:13px; font-weight:600; color:#374151; margin:14px 0 6px; text-transform:uppercase; letter-spacing:.04em; }
  .ro-grid { display:grid; grid-template-columns:repeat(2, minmax(0,1fr)); gap:8px 28px; font-size:13px; }
  .ro-grid.cols-3 { grid-template-columns:repeat(3, minmax(0,1fr)); }
  .ro-grid.cols-4 { grid-template-columns:repeat(4, minmax(0,1fr)); }
  .ro-row { display:flex; flex-direction:column; gap:1px; padding:4px 0; border-bottom:1px dashed #f3f4f6; }
  .ro-row.full { grid-column:1 / -1; }
  .ro-row .ro-label { font-size:11px; color:#6b7280; text-transform:uppercase; letter-spacing:.04em; }
  .ro-row .ro-value { font-size:14px; color:#111827; white-space:pre-wrap; }
  .ro-pill { display:inline-block; padding:.1rem .55rem; border-radius:9999px; background:#eef2ff; color:#3730a3; font-size:11px; font-weight:600; }
  .ro-fc-table { width:100%; border-collapse:collapse; font-size:12px; }
  .ro-fc-table th, .ro-fc-table td { padding:6px 8px; border-bottom:1px solid #e5e7eb; text-align:right; }
  .ro-fc-table th { background:#f9fafb; color:#374151; text-align:center; font-weight:600; }
  .ro-fc-table th:first-child, .ro-fc-table td:first-child { text-align:left; }
  .ro-fc-table .ro-total { background:#eff6ff; font-weight:600; color:#1e3a8a; }
</style>

<!-- Initiate / project header -->
<div class="ro-card">
  <h2>Initiate</h2>
  <div class="ro-grid">
    <div class="ro-row">
      <span class="ro-label">Request type</span>
      <span class="ro-value"><%= pr.request_type ? pr.request_type.replace(/_/g,' ') : '—' %></span>
    </div>
    <div class="ro-row">
      <span class="ro-label">Request date</span>
      <span class="ro-value"><%= show(pr.request_date) %></span>
    </div>
    <div class="ro-row">
      <span class="ro-label">Requestor</span>
      <span class="ro-value"><%= show(pr.requestor_name) %><% if (pr.requestor_email) { %> &lt;<%= pr.requestor_email %>&gt;<% } %></span>
    </div>
    <div class="ro-row">
      <span class="ro-label">Product name</span>
      <span class="ro-value"><%= show(pr.product_name) %></span>
    </div>
    <% if (rp.sku) { %>
      <div class="ro-row full">
        <span class="ro-label">Reference product</span>
        <span class="ro-value">
          <span class="ro-pill"><%= rp.sku %></span> <%= rp.name %>
          <% if (rp.brand) { %> · <%= rp.brand %><% } %>
          <% if (rp.bom && rp.bom.length) { %>
            · <%= rp.bom.length %>-line BOM available for reuse
          <% } %>
        </span>
      </div>
    <% } %>
  </div>
</div>

<!-- 1) Marketing -->
<div class="ro-card">
  <h2>1 · Marketing</h2>
  <div class="ro-grid">
    <div class="ro-row">
      <span class="ro-label">Target market</span>
      <span class="ro-value">
        <% var marketRow = (ref && ref.PRODUCT_MARKETS || []).find(function (m) { return m.code === mk.market; }); %>
        <%= marketRow ? (marketRow.name + ' (' + marketRow.currency + ')') : show(mk.market) %>
      </span>
    </div>
    <div class="ro-row">
      <span class="ro-label">Packaging / Formula</span>
      <span class="ro-value">
        Packaging: <strong><%= show(mk.packaging_status) %></strong>
        · Formula: <strong><%= show(mk.formula_status) %></strong>
      </span>
    </div>
    <div class="ro-row full">
      <span class="ro-label">Rationale</span>
      <span class="ro-value"><%= show(mk.rationale) %></span>
    </div>
    <div class="ro-row full">
      <span class="ro-label">Competitor &amp; Market Positioning</span>
      <span class="ro-value"><%= show(mk.positioning) %></span>
    </div>
    <div class="ro-row full">
      <span class="ro-label">Launch Plan</span>
      <span class="ro-value"><%= show(mk.launch_plan) %></span>
    </div>
  </div>
</div>

<!-- 2) Brand -->
<div class="ro-card">
  <h2>2 · Brand</h2>
  <div class="ro-grid cols-3">
    <div class="ro-row"><span class="ro-label">Category Grouper</span><span class="ro-value"><%= show(br.category_grouper) %></span></div>
    <div class="ro-row"><span class="ro-label">Category</span><span class="ro-value"><%= show(br.category) %></span></div>
    <div class="ro-row"><span class="ro-label">Family Brand</span><span class="ro-value"><%= show(br.family_brand) %></span></div>
    <div class="ro-row"><span class="ro-label">Brand</span><span class="ro-value"><%= show(br.brand) %></span></div>
    <div class="ro-row"><span class="ro-label">Sub Brand</span><span class="ro-value"><%= show(br.sub_brand) %></span></div>
  </div>
</div>

<!-- 3) R&D -->
<div class="ro-card">
  <h2>3 · R&amp;D</h2>
  <h3>SAP classification</h3>
  <div class="ro-grid">
    <div class="ro-row"><span class="ro-label">Material Type (SAP)</span><span class="ro-value"><%= show(rnd.material_type) %></span></div>
    <div class="ro-row"><span class="ro-label">Base UoM</span><span class="ro-value"><%= show(rnd.base_uom) %></span></div>
  </div>

  <h3>Dimensions</h3>
  <div class="ro-grid cols-4">
    <div class="ro-row"><span class="ro-label">Length</span><span class="ro-value"><%= fmt(rnd.length) %> <%= rnd.dim_unit || '' %></span></div>
    <div class="ro-row"><span class="ro-label">Width</span><span class="ro-value"><%= fmt(rnd.width) %> <%= rnd.dim_unit || '' %></span></div>
    <div class="ro-row"><span class="ro-label">Height</span><span class="ro-value"><%= fmt(rnd.height) %> <%= rnd.dim_unit || '' %></span></div>
    <div class="ro-row"><span class="ro-label">Volume</span><span class="ro-value"><%= fmt(rnd.volume) %> <%= rnd.volume_unit || '' %></span></div>
    <div class="ro-row"><span class="ro-label">Net Weight</span><span class="ro-value"><%= fmt(rnd.net_weight) %> <%= rnd.weight_unit || '' %></span></div>
    <div class="ro-row"><span class="ro-label">Gross Weight</span><span class="ro-value"><%= fmt(rnd.gross_weight) %> <%= rnd.weight_unit || '' %></span></div>
  </div>

  <h3>Pricing</h3>
  <div class="ro-grid cols-3">
    <div class="ro-row"><span class="ro-label">Manufacturing Price</span><span class="ro-value"><%= fmt(rnd.mfg_price) %> <%= rnd.mfg_price_ccy || '' %></span></div>
    <div class="ro-row"><span class="ro-label">Retail Price (USD)</span><span class="ro-value"><%= fmt(rnd.retail_price_usd) %> USD</span></div>
    <div class="ro-row"><span class="ro-label">Retail Price (Local)</span><span class="ro-value"><%= fmt(rnd.retail_price_local) %> <%= rnd.retail_price_local_ccy || '' %></span></div>
    <% if (rnd.fx_rate) { %>
      <div class="ro-row full">
        <span class="ro-label">FX Rate captured at submit</span>
        <span class="ro-value">1 USD = <strong><%= rnd.fx_rate %></strong> <%= rnd.retail_price_local_ccy || '' %>
          · <%= rnd.fx_as_of || '' %>
          <% if (rnd.fx_source) { %> · <em><%= rnd.fx_source %></em><% } %>
        </span>
      </div>
    <% } %>
  </div>

  <h3>Contract</h3>
  <div class="ro-grid">
    <div class="ro-row"><span class="ro-label">Status</span><span class="ro-value"><%= show(rnd.contract_status && rnd.contract_status.replace(/_/g,' ')) %></span></div>
    <div class="ro-row"><span class="ro-label">Supplier</span><span class="ro-value"><%= show(rnd.contract_supplier) %></span></div>
  </div>
</div>

<!-- 4) Forecast -->
<div class="ro-card">
  <h2>4 · Forecast</h2>
  <table class="ro-fc-table">
    <thead>
      <tr>
        <th>Period</th>
        <% ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'].forEach(function (m) { %><th><%= m %></th><% }); %>
        <th>Total</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td><strong>Year 1</strong></td>
        <% ['jan','feb','mar','apr','may','jun','jul','aug','sep','oct','nov','dec'].forEach(function (m) { %>
          <td><%= fmt(fc['y1_' + m]) %></td>
        <% }); %>
        <td class="ro-total"><%= fmt(fc.total_y1) %></td>
      </tr>
    </tbody>
  </table>
  <div class="ro-grid cols-4" style="margin-top:10px;">
    <div class="ro-row"><span class="ro-label">Year 2</span><span class="ro-value"><%= fmt(fc.y2) %></span></div>
    <div class="ro-row"><span class="ro-label">Year 3</span><span class="ro-value"><%= fmt(fc.y3) %></span></div>
    <div class="ro-row"><span class="ro-label">Year 4</span><span class="ro-value"><%= fmt(fc.y4) %></span></div>
    <div class="ro-row"><span class="ro-label">Year 5</span><span class="ro-value"><%= fmt(fc.y5) %></span></div>
    <div class="ro-row full"><span class="ro-label">5-Year Total</span><span class="ro-value"><strong style="font-size:16px;color:#1e3a8a;"><%= fmt(fc.total_y5) %></strong></span></div>
  </div>
</div>

<% if (pr.production_completed_at || prodPlan.launch_start_date) { %>
  <!-- 5) Production (R&D) -->
  <div class="ro-card">
    <h2>5 · Production (R&amp;D)
      <% if (pr.production_completed_at) { %>
        <span class="ro-pill" style="background:#dcfce7;color:#166534;">Submitted <%= pr.production_completed_at %></span>
      <% } else { %>
        <span class="ro-pill" style="background:#fef3c7;color:#92400e;">In progress</span>
      <% } %>
    </h2>
    <h3>Production plan</h3>
    <div class="ro-grid cols-3">
      <div class="ro-row"><span class="ro-label">Launch start</span><span class="ro-value"><%= show(prodPlan.launch_start_date) %></span></div>
      <div class="ro-row"><span class="ro-label">Launch target</span><span class="ro-value"><%= show(prodPlan.launch_target_date) %></span></div>
      <div class="ro-row"><span class="ro-label">Lead time</span><span class="ro-value"><%= prodPlan.lead_time_weeks != null ? (prodPlan.lead_time_weeks + ' weeks') : '—' %></span></div>
    </div>
    <h3>Packaging</h3>
    <div class="ro-grid cols-3">
      <div class="ro-row"><span class="ro-label">Origin</span><span class="ro-value"><%= show(prodPkg.origin) %></span></div>
      <div class="ro-row"><span class="ro-label">Launch type</span><span class="ro-value"><%= show(prodPkg.launch_type && prodPkg.launch_type.replace(/_/g,' ')) %></span></div>
      <div class="ro-row"><span class="ro-label">Region / Country</span><span class="ro-value"><%= show(prodPkg.region) %><% if (prodPkg.country) { %> · <%= prodPkg.country %><% } %></span></div>
      <div class="ro-row full"><span class="ro-label">Site</span><span class="ro-value"><%= show(prodPkg.site) %></span></div>
    </div>
    <h3>Formula</h3>
    <div class="ro-grid cols-3">
      <div class="ro-row"><span class="ro-label">Origin</span><span class="ro-value"><%= show(prodFrm.origin) %></span></div>
      <div class="ro-row"><span class="ro-label">Category</span><span class="ro-value"><%= show(prodFrm.category) %></span></div>
      <div class="ro-row"><span class="ro-label">Class</span><span class="ro-value"><%= show(prodFrm.class) %></span></div>
      <div class="ro-row"><span class="ro-label">Brand</span><span class="ro-value"><%= show(prodFrm.brand_tier) %></span></div>
      <div class="ro-row"><span class="ro-label">Formula type</span><span class="ro-value"><%= show(prodFrm.formula_type) %></span></div>
      <div class="ro-row"><span class="ro-label">Flavor</span><span class="ro-value"><%= show(prodFrm.flavor) %></span></div>
      <div class="ro-row"><span class="ro-label">Color</span><span class="ro-value"><%= show(prodFrm.color) %></span></div>
      <div class="ro-row"><span class="ro-label">Appearance</span><span class="ro-value"><%= show(prodFrm.appearance) %></span></div>
      <div class="ro-row"><span class="ro-label">Cold storage</span><span class="ro-value"><%= show(prodFrm.cold_storage) %></span></div>
      <div class="ro-row"><span class="ro-label">Carbonated</span><span class="ro-value"><%= show(prodFrm.carbonated) %></span></div>
    </div>
    <% if (prodFrm.certificates && prodFrm.certificates.length) { %>
      <h3>Legal certificates</h3>
      <ul style="font-size:13px; padding-left:18px; list-style:disc; color:#374151;">
        <% prodFrm.certificates.forEach(function (c) { %>
          <li>
            <strong><%= c.code %></strong>
            <% if (c.comment) { %> — <em><%= c.comment %></em><% } %>
            <%
              var fileMatches = atts.filter(function (a) { return a.certificate_type === c.code; });
              fileMatches.forEach(function (f) { %>
              · <a href="/products/workflow/<%= pr.id %>/attachments/<%= f.id %>" class="text-blue-600 hover:underline" target="_blank"><%= f.original_name %></a>
            <% }); %>
          </li>
        <% }); %>
      </ul>
    <% } %>
  </div>
<% } %>

<% if (pr.packaging_completed_at || pkmMat.material_type) { %>
  <!-- 5b) Packaging Materials (R&D) -->
  <div class="ro-card">
    <h2>5b · Packaging Materials (R&amp;D)
      <% if (pr.packaging_completed_at) { %>
        <span class="ro-pill" style="background:#dcfce7;color:#166534;">Submitted <%= pr.packaging_completed_at %></span>
      <% } else { %>
        <span class="ro-pill" style="background:#fef3c7;color:#92400e;">In progress</span>
      <% } %>
    </h2>
    <h3>Materials</h3>
    <div class="ro-grid cols-3">
      <div class="ro-row"><span class="ro-label">Status</span><span class="ro-value"><%= show(pkmMat.status) %></span></div>
      <div class="ro-row"><span class="ro-label">Material type</span><span class="ro-value"><%= show(pkmMat.material_type) %></span></div>
      <div class="ro-row"><span class="ro-label">Units per case</span><span class="ro-value"><%= show(pkmMat.units_per_case) %><% if (pkmMat.case_pack_label) { %> (<%= pkmMat.case_pack_label %>)<% } %></span></div>
      <div class="ro-row"><span class="ro-label">Height × Width</span><span class="ro-value"><%= fmt(pkmMat.height) %> × <%= fmt(pkmMat.width) %> <%= pkmMat.dim_unit || '' %></span></div>
      <div class="ro-row"><span class="ro-label">Volume</span><span class="ro-value"><%= fmt(pkmMat.volume) %> <%= pkmMat.volume_unit || '' %></span></div>
    </div>
    <% if (pkmMat.description) { %>
      <div class="ro-row full"><span class="ro-label">Description</span><span class="ro-value"><%= pkmMat.description %></span></div>
    <% } %>

    <% if (pkmComps.length) { %>
      <h3>Components</h3>
      <table class="ro-fc-table">
        <thead><tr><th>Component</th><th>Status</th><th>Description</th></tr></thead>
        <tbody>
          <% pkmComps.forEach(function (c) { %>
            <tr>
              <td style="text-align:left;"><%= c.code %></td>
              <td><%= c.status %></td>
              <td style="text-align:left;"><%= c.description || '—' %></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    <% } %>

    <% if (pkmInco.length) { %>
      <h3>Incoterms</h3>
      <ul style="font-size:13px; padding-left:18px; list-style:disc; color:#374151;">
        <% pkmInco.forEach(function (i) { %>
          <li><strong><%= i.code %></strong><% if (i.description) { %> — <em><%= i.description %></em><% } %></li>
        <% }); %>
      </ul>
    <% } %>

    <h3>Updated cost &amp; price</h3>
    <div class="ro-grid cols-3">
      <div class="ro-row"><span class="ro-label">Cost (Local)</span><span class="ro-value"><%= fmt(pkmCost.cost_local) %> <%= pkmCost.cost_local_ccy || '' %></span></div>
      <div class="ro-row"><span class="ro-label">Cost (USD)</span> <span class="ro-value"><%= fmt(pkmCost.cost_usd) %> USD</span></div>
      <div class="ro-row"></div>
      <div class="ro-row"><span class="ro-label">Shelf (Local)</span><span class="ro-value"><%= fmt(pkmCost.shelf_local) %> <%= pkmCost.shelf_local_ccy || '' %></span></div>
      <div class="ro-row"><span class="ro-label">Shelf (USD)</span> <span class="ro-value"><%= fmt(pkmCost.shelf_usd) %> USD</span></div>
    </div>

    <% if (pkmVol.total_y1 != null || pkmVol.total_y5 != null) { %>
      <h3>Updated volumes (cases)</h3>
      <table class="ro-fc-table">
        <thead><tr><th>Period</th>
          <% ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'].forEach(function (m) { %><th><%= m %></th><% }); %>
          <th>Total</th></tr>
        </thead>
        <tbody>
          <tr>
            <td><strong>Year 1</strong></td>
            <% ['jan','feb','mar','apr','may','jun','jul','aug','sep','oct','nov','dec'].forEach(function (m) { %>
              <td><%= fmt(pkmVol['y1_' + m]) %></td>
            <% }); %>
            <td class="ro-total"><%= fmt(pkmVol.total_y1) %></td>
          </tr>
        </tbody>
      </table>
      <div class="ro-grid cols-4" style="margin-top:8px;">
        <div class="ro-row"><span class="ro-label">Year 2</span><span class="ro-value"><%= fmt(pkmVol.y2) %></span></div>
        <div class="ro-row"><span class="ro-label">Year 3</span><span class="ro-value"><%= fmt(pkmVol.y3) %></span></div>
        <div class="ro-row"><span class="ro-label">Year 4</span><span class="ro-value"><%= fmt(pkmVol.y4) %></span></div>
        <div class="ro-row"><span class="ro-label">Year 5</span><span class="ro-value"><%= fmt(pkmVol.y5) %></span></div>
        <div class="ro-row full"><span class="ro-label">5-Year Total</span><span class="ro-value"><strong style="font-size:15px;color:#1e3a8a;"><%= fmt(pkmVol.total_y5) %></strong></span></div>
      </div>
    <% } %>

    <% if (pkm.inventory_agreement || pkm.rationale_price || pkm.rationale_volume) { %>
      <h3>Inventory &amp; rationale</h3>
      <% if (pkm.inventory_agreement) { %>
        <div class="ro-row full"><span class="ro-label">Inventory agreement</span><span class="ro-value"><%= pkm.inventory_agreement %></span></div>
      <% } %>
      <% if (pkm.rationale_price) { %>
        <div class="ro-row full"><span class="ro-label">Rationale — price</span><span class="ro-value"><%= pkm.rationale_price %></span></div>
      <% } %>
      <% if (pkm.rationale_volume) { %>
        <div class="ro-row full"><span class="ro-label">Rationale — volume</span><span class="ro-value"><%= pkm.rationale_volume %></span></div>
      <% } %>
    <% } %>

    <% if (pkmComp.length) { %>
      <h3>Cross-market comparisons</h3>
      <table class="ro-fc-table">
        <thead><tr><th>SKU</th><th>Product</th><th>Market</th><th>Shelf (local)</th><th>CCY</th><th>Shelf (USD)</th></tr></thead>
        <tbody>
          <% pkmComp.forEach(function (c) {
               var marketRow = (ref.PRODUCT_MARKETS || []).find(function (m) { return m.code === c.market; });
          %>
            <tr>
              <td style="text-align:left;"><%= show(c.sku) %></td>
              <td style="text-align:left;"><%= show(c.name) %></td>
              <td style="text-align:left;"><%= marketRow ? marketRow.name : (c.market || '—') %></td>
              <td><%= fmt(c.shelf_local) %></td>
              <td><%= show(c.shelf_local_ccy) %></td>
              <td><%= fmt(c.shelf_usd) %></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    <% } %>
  </div>
<% } %>

<% if (pr.design_completed_at || (dsn.agency && dsn.agency.name) || dsnAtts.length) { %>
  <!-- 5c) Design (R&D, parallel with Packaging) -->
  <div class="ro-card">
    <h2>5c · Design (R&amp;D)
      <% if (pr.design_completed_at) { %>
        <span class="ro-pill" style="background:#dcfce7;color:#166534;">Submitted <%= pr.design_completed_at %></span>
      <% } else { %>
        <span class="ro-pill" style="background:#fef3c7;color:#92400e;">In progress</span>
      <% } %>
    </h2>
    <h3>Brief</h3>
    <div class="ro-grid">
      <div class="ro-row full"><span class="ro-label">Required languages</span><span class="ro-value">
        <%= ((dsn.brief && dsn.brief.languages) || []).map(function (c) {
          var m = (ref.LANGUAGES || []).find(function (x) { return x.code === c; });
          return m ? m.label : c;
        }).join(', ') || '—' %>
      </span></div>
      <% if (dsn.brief && dsn.brief.notes) { %>
        <div class="ro-row full"><span class="ro-label">Brief notes</span><span class="ro-value"><%= dsn.brief.notes %></span></div>
      <% } %>
      <% if ((dsnByCat.design_brief || [])[0]) { var f = dsnByCat.design_brief[0]; %>
        <div class="ro-row full"><span class="ro-label">Design brief file</span><span class="ro-value">
          <a href="/products/workflow/<%= pr.id %>/attachments/<%= f.id %>" class="text-blue-600 hover:underline" target="_blank"><%= f.original_name %></a>
        </span></div>
      <% } %>
      <% if ((dsnByCat.design_translation || [])[0]) { var f = dsnByCat.design_translation[0]; %>
        <div class="ro-row full"><span class="ro-label">Translation file</span><span class="ro-value">
          <a href="/products/workflow/<%= pr.id %>/attachments/<%= f.id %>" class="text-blue-600 hover:underline" target="_blank"><%= f.original_name %></a>
        </span></div>
      <% } %>
    </div>

    <h3>Agency</h3>
    <div class="ro-grid cols-3">
      <div class="ro-row"><span class="ro-label">Name</span><span class="ro-value"><%= show(dsn.agency && dsn.agency.name) %></span></div>
      <div class="ro-row"><span class="ro-label">Vendor code</span><span class="ro-value"><%= show(dsn.agency && dsn.agency.vendor_code) %></span></div>
      <div class="ro-row"><span class="ro-label">Contact</span><span class="ro-value"><%= show(dsn.agency && dsn.agency.contact) %></span></div>
      <div class="ro-row"><span class="ro-label">Email</span><span class="ro-value"><%= show(dsn.agency && dsn.agency.email) %></span></div>
      <div class="ro-row"><span class="ro-label">Phone</span><span class="ro-value"><%= show(dsn.agency && dsn.agency.phone) %></span></div>
    </div>

    <% if (dsn.label) { var L = dsn.label; if (L.marketing_text || L.claims || L.legal_claims || L.environmental_claims || L.nutritional_claims || L.dietary_claims || L.contacts) { %>
      <h3>Label content</h3>
      <% [
        ['Marketing text',       L.marketing_text],
        ['Claims',               L.claims],
        ['Legal claims',         L.legal_claims],
        ['Environmental claims', L.environmental_claims],
        ['Nutritional claims',   L.nutritional_claims],
        ['Dietary claims',       L.dietary_claims],
        ['Contacts',             L.contacts],
      ].forEach(function (pair) { if (pair[1]) { %>
        <div class="ro-row full"><span class="ro-label"><%= pair[0] %></span><span class="ro-value"><%= pair[1] %></span></div>
      <% }}); %>
    <% }} %>

    <% if ((dsnByCat.design_label || []).length || (dsnByCat.design_logo || []).length || (dsnByCat.design_pictogram || []).length || (dsnByCat.design_symbol || []).length) { %>
      <h3>Visual assets</h3>
      <% [
        ['Label image', dsnByCat.design_label || []],
        ['Logos',       dsnByCat.design_logo  || []],
        ['Pictograms',  dsnByCat.design_pictogram || []],
        ['Symbols',     dsnByCat.design_symbol || []],
      ].forEach(function (pair) { if (pair[1].length) { %>
        <div class="ro-row full"><span class="ro-label"><%= pair[0] %> (<%= pair[1].length %>)</span><span class="ro-value">
          <% pair[1].forEach(function (a) { %>
            <a href="/products/workflow/<%= pr.id %>/attachments/<%= a.id %>" class="text-blue-600 hover:underline" target="_blank" style="margin-right:8px;"><%= a.original_name %></a>
          <% }); %>
        </span></div>
      <% }}); %>
    <% } %>
  </div>
<% } %>

<% if (pr.competitor_completed_at || cmp.market_type) { %>
  <!-- 6) Competitor Analysis -->
  <div class="ro-card">
    <h2>6 · Competitor Analysis (Marketing)
      <% if (pr.competitor_completed_at) { %>
        <span class="ro-pill" style="background:#dcfce7;color:#166534;">Submitted <%= pr.competitor_completed_at %></span>
      <% } else { %>
        <span class="ro-pill" style="background:#fef3c7;color:#92400e;">In progress</span>
      <% } %>
    </h2>
    <div class="ro-grid">
      <div class="ro-row"><span class="ro-label">Market type</span><span class="ro-value"><%= show(cmp.market_type) %></span></div>
      <div class="ro-row"><span class="ro-label">Positioning</span><span class="ro-value"><%= show(cmp.positioning) %></span></div>
      <div class="ro-row full"><span class="ro-label">Destination countries</span><span class="ro-value">
        <%= (cmp.countries || []).map(function (c) {
          var m = (ref.PRODUCT_MARKETS || []).find(function (x) { return x.code === c; });
          return m ? m.name : c;
        }).join(', ') || '—' %>
      </span></div>
      <div class="ro-row full"><span class="ro-label">Distribution channels</span><span class="ro-value">
        <%= (cmp.channels || []).map(function (c) {
          var m = (ref.DISTRIBUTION_CHANNELS || []).find(function (x) { return x.code === c; });
          return m ? m.label : c;
        }).join(', ') || '—' %>
      </span></div>
      <div class="ro-row full"><span class="ro-label">Target ages</span><span class="ro-value">
        <%= (cmp.target_ages || []).map(function (c) {
          var m = (ref.TARGET_AGE_GROUPS || []).find(function (x) { return x.code === c; });
          return m ? m.label : c;
        }).join(', ') || '—' %>
      </span></div>
    </div>
    <% if (cmp.competitors && cmp.competitors.length) { %>
      <h3>Competitor pricing</h3>
      <table class="ro-fc-table">
        <thead><tr><th>Competitor</th><th>Product</th><th>Price (local)</th><th>Local CCY</th><th>Price (USD)</th></tr></thead>
        <tbody>
          <% cmp.competitors.forEach(function (c) { %>
            <tr>
              <td style="text-align:left;"><%= show(c.name) %></td>
              <td style="text-align:left;"><%= show(c.product) %></td>
              <td><%= fmt(c.price_local) %></td>
              <td><%= show(c.price_local_ccy) %></td>
              <td><%= fmt(c.price_usd) %></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    <% } %>
    <% if (cmp.market_trends) { %>
      <h3>Market trends</h3>
      <div class="ro-row full" style="border-bottom:none;"><span class="ro-value"><%= cmp.market_trends %></span></div>
    <% } %>
  </div>
<% } %>
