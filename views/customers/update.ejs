<%- include('../partials/head', { pageTitle: 'Update ' + customer.legal_name }) %>
<%- include('../partials/nav') %>
<div class="main-content">
<%- include('../partials/topbar', { topTitle: 'Update: ' + customer.legal_name, topSub: kind.toUpperCase().replace('-',' ') + ' request · requires approval' }) %>
<main class="p-6 max-w-3xl">

<form method="post" action="/customers/<%= customer.id %>/update/<%= kind %>" class="space-y-6">

  <% if (kind === 'general') { %>
    <section class="card">
      <div class="card-header"><h3 class="font-semibold">General info update</h3></div>
      <div class="card-body grid grid-cols-1 md:grid-cols-2 gap-4">
        <label class="field"><span class="label">Legal name</span>
          <input name="legal_name" value="<%= customer.legal_name %>" class="input"></label>
        <label class="field"><span class="label">Tax ID</span>
          <input name="tax_id" value="<%= customer.tax_id || '' %>" class="input"></label>
        <label class="field"><span class="label">Credit limit</span>
          <input name="credit_limit" type="number" step="0.01" value="<%= customer.credit_limit || '' %>" class="input"></label>
        <label class="field"><span class="label">Payment terms</span>
          <select name="payment_terms" class="input">
            <% (ref.PAYMENT_TERM || []).forEach(c => { %><option value="<%= c.code %>" <%= customer.payment_terms===c.code ? 'selected':'' %>><%= c.label %></option><% }) %>
          </select></label>
      </div>
    </section>
  <% } else if (kind === 'company-code') { %>
    <section class="card">
      <div class="card-header"><h3 class="font-semibold">Company code extension</h3></div>
      <div class="card-body grid grid-cols-1 md:grid-cols-2 gap-4">
        <label class="field"><span class="label">New company code *</span><input name="company_code" required class="input"></label>
        <label class="field"><span class="label">Currency *</span>
          <select name="currency_code" required class="input">
            <% (ref.CURRENCY || []).forEach(c => { %><option value="<%= c.code %>"><%= c.code %> — <%= c.label %></option><% }) %>
          </select></label>
        <label class="field"><span class="label">Payment terms *</span>
          <select name="payment_terms" required class="input">
            <% (ref.PAYMENT_TERM || []).forEach(c => { %><option value="<%= c.code %>"><%= c.label %></option><% }) %>
          </select></label>
        <label class="field"><span class="label">Credit limit</span><input name="credit_limit" type="number" step="0.01" class="input"></label>
      </div>
    </section>
  <% } else if (kind === 'sales-area') { %>
    <section class="card">
      <div class="card-header"><h3 class="font-semibold">Sales area extension</h3></div>
      <div class="card-body grid grid-cols-1 md:grid-cols-2 gap-4">
        <label class="field"><span class="label">Sales org *</span>
          <select name="sales_org" required class="input">
            <% (ref.SALES_ORG || []).forEach(c => { %><option value="<%= c.code %>"><%= c.label %></option><% }) %>
          </select></label>
        <label class="field"><span class="label">Distribution channel *</span>
          <select name="dist_channel" required class="input">
            <option>DIRECT</option><option>RESELLER</option><option>DISTRIBUTOR</option><option>OEM</option>
          </select></label>
        <label class="field"><span class="label">Division</span><input name="division" class="input"></label>
      </div>
    </section>
  <% } %>

  <section class="card">
    <div class="card-header"><h3 class="font-semibold">Justification</h3></div>
    <div class="card-body">
      <label class="field"><span class="label">Reason *</span>
        <textarea name="reason" rows="3" required class="input"></textarea></label>
    </div>
  </section>

  <div class="flex gap-2">
    <button class="btn btn-primary">Submit for approval →</button>
    <a href="/customers/<%= customer.id %>" class="btn btn-ghost">Cancel</a>
  </div>
</form>

</main></div>
</body></html>
