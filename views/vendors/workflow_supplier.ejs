<%
/*
  workflow_supplier.ejs
  -----------------------------------------------------------------------------
  Stage 3 — Supplier self-service form. The external supplier fills in their
  own details (banking, contacts, documents, certifications).

  FIELDS TODO: add the supplier-provided form fields inside the marked section.
  -----------------------------------------------------------------------------
*/
%>
<%- include('../partials/header', { title: 'Supplier Form' }) %>

<main class="mx-auto max-w-4xl px-4 py-8">
  <%- include('_workflow_shared', { vendor: vendor, stateLabel: stateLabel, history: history, comments: comments }) %>

  <form method="post" action="/vendors/<%= vendor.id %>/workflow/supplier"
        class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm space-y-6">

    <div>
      <h2 class="text-lg font-semibold text-gray-900">Supplier details</h2>
      <p class="mt-1 text-sm text-gray-500">
        Please complete the fields below. All information is confidential.
      </p>
    </div>

    <!-- ===================== SUPPLIER FIELDS — TODO ========================== -->
    <div class="rounded border border-dashed border-gray-300 bg-gray-50 p-4 text-sm text-gray-500">
      Placeholder for supplier-filled fields (banking details, contacts,
      certifications, document uploads, etc.). Field list pending.
    </div>
    <!-- ======================================================================= -->

    <div>
      <label class="block">
        <span class="text-sm font-medium text-gray-700">Comments (optional)</span>
        <textarea name="comment" rows="3"
                  class="mt-1 w-full rounded border border-gray-300 p-2 text-sm"></textarea>
      </label>
    </div>

    <div class="flex justify-end gap-3">
      <a href="/vendors/queue" class="rounded px-4 py-2 text-sm text-gray-700 hover:bg-gray-100">Save draft</a>
      <button type="submit" class="rounded bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">
        Submit to iDOT
      </button>
    </div>
  </form>
</main>

<%- include('../partials/footer') %>
