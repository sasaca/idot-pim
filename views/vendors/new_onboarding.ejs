          <!-- Per-country Tax ID validation. Looks up rules by ISO2 (resolved
               from the country select via PHONE_BY_COUNTRY) and tests the
               value against every accepted format for that country. Falls
               back to the _default rule for countries with no specific entry. -->
          <script id="tax-id-rules" type="application/json"><%- JSON.stringify(lookups.TAX_ID_RULES) %></script>
          <script>
          (function () {
            var RULES = JSON.parse(document.getElementById('tax-id-rules').textContent || '{}');
            var BY_COUNTRY = JSON.parse(document.getElementById('phone-codes-by-country').textContent || '{}');
            var countrySel = document.querySelector('[data-country-name]');
            var taxInput   = document.querySelector('[data-tax-id]');
            var labelEl    = document.getElementById('tax-id-label');
            var errorEl    = document.getElementById('tax-id-error');
            if (!countrySel || !taxInput || !errorEl) return;

            function rulesForCountry() {
              var rec = BY_COUNTRY[countrySel.value];
              var iso2 = rec && rec.iso2;
              return (iso2 && RULES[iso2]) || RULES._default;
            }

            function setLabel(rule) {
              if (!labelEl) return;
              labelEl.textContent = 'Tax ID / EIN' + (rule && rule.label ? ' (' + rule.label + ')' : '');
            }

            function setError(html) {
              if (html) {
                errorEl.innerHTML = html;
                errorEl.style.color = '#b91c1c';
                taxInput.style.borderColor = '#fca5a5';
              } else {
                errorEl.innerHTML = '';
                errorEl.style.color = '#6b7280';
                taxInput.style.borderColor = '';
              }
            }

            function formatList(rule) {
              return (rule.formats || []).map(function (f) {
                return '<li>' + f.description + '</li>';
              }).join('');
            }

            function validate() {
              var rule = rulesForCountry();
              setLabel(rule);
              var raw = (taxInput.value || '').trim().toUpperCase();
              if (!raw) { setError(''); return; }
              var ok = (rule.formats || []).some(function (f) {
                try { return new RegExp(f.pattern).test(raw); }
                catch (e) { return false; }
              });
              if (ok) {
                setError('');
              } else {
                setError(
                  'Tax ID does not match an accepted format for this country. Accepted formats:<ul style="margin:4px 0 0 18px;list-style:disc;">' +
                  formatList(rule) + '</ul>'
                );
              }
            }

            countrySel.addEventListener('change', validate);
            taxInput.addEventListener('input', validate);
            taxInput.addEventListener('blur', validate);
            // Initialize label from default rule on first render.
            setLabel(rulesForCountry());
          })();
          </script>

          <!-- DUNS # validation. D&B issues 9-digit numeric identifiers; we
               accept hyphens / spaces in input but require exactly 9 digits
               after stripping. Applies to both DUNS and Parent DUNS fields. -->
          <script>
          (function () {
            document.querySelectorAll('[data-duns]').forEach(function (input) {
              var errorEl = input.parentElement.querySelector('.duns-error');
              function validate() {
                var raw = (input.value || '').trim();
                var digits = raw.replace(/[\s-]/g, '');
                if (!raw) {
                  input.style.borderColor = '';
                  if (errorEl) { errorEl.textContent = ''; errorEl.style.color = '#6b7280'; }
                  return;
                }
                var ok = /^\d{9}$/.test(digits);
                if (ok) {
                  input.style.borderColor = '';
                  if (errorEl) { errorEl.textContent = ''; errorEl.style.color = '#6b7280'; }
                } else {
                  input.style.borderColor = '#fca5a5';
                  if (errorEl) {
                    errorEl.textContent = 'DUNS # must be exactly 9 digits (got ' + digits.length + ').';
                    errorEl.style.color = '#b91c1c';
                  }
                }
              }
              input.addEventListener('input', validate);
              input.addEventListener('blur', validate);
            });
          })();
          </script>

