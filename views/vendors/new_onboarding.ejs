<%
/*
  views/vendors/new_onboarding.ejs
  ---------------------------------------------------------------------------
  Initial Vendor Onboarding form — tabbed, 10 sections.

  Tabs:
    1. Document Upload
    2. General Information  (supplier name, address, primary contact)
    3. Requestor Information
    4. Vendor Category
    5. Duplicate Check
    6. Vendor Additional Details
    7. Compliance Questions
    8. Sustainability Questions
    9. CSR Score
   10. Scope of Work

  Notes for the developer filling this in later:
   - Every <select> currently has a minimal option list. Swap in real lookup
     values from your reference tables once known.
   - All inputs share one <form>, one submit. Tabs are just JS-swapped panes;
     hidden panes still post their values on submit.
   - Required fields are flagged with a red asterisk AND `required` attribute.
   - The document upload partial and the address autocomplete partial are
     pulled in exactly as before — they already know how to populate fields
     here by name.
*/
%>
<%- include('../partials/head', { pageTitle: 'Vendor Onboarding Request' }) %>
<%- include('../partials/nav') %>
<div class="main-content">
<%- include('../partials/topbar', { topTitle: 'Vendor Onboarding Request', topSub: 'Submit a full vendor onboarding request. Saves as draft or advances to Supply Chain review.' }) %>

<style>
  /* Tab navigation — left rail. */
  .vob-shell { display: block; }

  /* Folder tabs — sit flush against the top of the card below, single row. */
  .vob-nav {
    display: flex;
    flex-wrap: nowrap;
    gap: 2px;
    padding: 0 6px;
    margin: 0 0 -1px 0;          /* overlap the card's top border by 1px */
    position: relative;
    z-index: 2;
    overflow-x: auto;            /* scroll only if viewport is very narrow */
  }
  .vob-nav h3 { display: none; }
  .vob-nav button {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 8px 14px; margin: 0;
    border: 1px solid #e5e7eb;
    border-radius: 8px 8px 0 0;
    background: #f3f4f6; color: #4b5563;
    font-size: 13px; cursor: pointer;
    white-space: nowrap;
    position: relative;
  }
  .vob-nav button:hover { background: #e5e7eb; }
  .vob-nav button.active {
    background: #fff; color: #111827; font-weight: 600;
    border-color: #e5e7eb;
    border-bottom-color: #fff;   /* mask the card's top border under the tab */
    z-index: 3;
  }
  .vob-nav .num {
    display: inline-flex; align-items: center; justify-content: center;
    width: 22px; height: 22px; border-radius: 4px;
    background: #e5e7eb; color: #374151; font-size: 12px; font-weight: 600;
  }
  .vob-nav button.active .num { background: #1e3a8a; color: #fff; }
  .vob-nav .vob-count {
    display: inline-block; padding: 1px 7px; font-size: 11px;
    border-radius: 9999px; background: #d1d5db; color: #374151;
    font-weight: 600;
  }
  .vob-nav button.active .vob-count { background: #e5e7eb; color: #111827; }
  /* Done — green whenever a tab's required fields are all filled. */
  .vob-nav button.done {
    background: #10b981; color: #fff; border-color: #10b981;
  }
  .vob-nav button.done .num,
  .vob-nav button.done .vob-count {
    background: rgba(255,255,255,0.35); color: #fff;
  }
  .vob-nav button.done.active {
    border-bottom-color: #10b981;
  }

  /* Panels */
  .vob-card {
    background: #fff; border: 1px solid #e5e7eb;
    border-radius: 0 0 8px 8px;   /* flat top — folder tabs sit on it */
    padding: 24px; box-shadow: 0 1px 2px rgba(0,0,0,0.04);
    position: relative; z-index: 1;
  }
  .vob-card h2 {
    font-size: 18px; font-weight: 600; color: #111827;
    margin: 0 0 4px;
  }
  .vob-card .indicates-required {
    color: #dc2626; font-size: 12px; margin-bottom: 14px;
  }
  .vob-card .section-title {
    font-size: 15px; font-weight: 600; color: #111827;
    border-bottom: 1px solid #e5e7eb; padding-bottom: 6px; margin: 18px 0 12px;
  }

  .vob-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 14px 20px;
  }
  @media (max-width: 700px) { .vob-grid { grid-template-columns: 1fr; } }

  .vob-field label {
    display: block; font-size: 13px; font-weight: 500; color: #374151;
    margin-bottom: 4px;
  }
  .vob-field label .req { color: #dc2626; margin-right: 3px; }

  .vob-field input[type=text],
  .vob-field input[type=email],
  .vob-field input[type=tel],
  .vob-field input[type=date],
  .vob-field input[type=number],
  .vob-field select,
  .vob-field textarea {
    width: 100%; padding: 8px 10px; font-size: 14px;
    border: 1px solid #d1d5db; border-radius: 6px; background: #fff;
    box-sizing: border-box;
  }
  .vob-field input:focus, .vob-field select:focus, .vob-field textarea:focus {
    outline: 2px solid #2563eb; outline-offset: -1px; border-color: #2563eb;
  }
  .vob-field[data-readonly] input { background: #f3f4f6; color: #6b7280; }
  .vob-field textarea { min-height: 80px; resize: vertical; }

  .vob-field.full { grid-column: 1 / -1; }

  /* Inline radio / checkbox groups */
  .radio-group, .check-group {
    display: flex; flex-wrap: wrap; gap: 10px 16px;
    padding: 6px 0 2px;
  }
  .radio-group label, .check-group label {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 6px 12px;
    font-size: 14px; font-weight: 400; color: #374151;
    border: 1px solid #d1d5db; border-radius: 999px;
    cursor: pointer; background: #fff;
    margin: 0; user-select: none;
  }
  .radio-group label:hover, .check-group label:hover {
    background: #f3f4f6; border-color: #9ca3af;
  }
  .radio-group input[type=radio], .check-group input[type=checkbox] {
    margin: 0; accent-color: #1e3a8a;
  }
  /* Highlight the label when its input is checked (pure-CSS pill effect) */
  .radio-group label:has(input:checked),
  .check-group label:has(input:checked) {
    background: #1e3a8a; color: #fff; border-color: #1e3a8a;
  }
  .radio-group label:has(input:checked) input,
  .check-group label:has(input:checked) input {
    accent-color: #fff;
  }

  /* Standalone checkbox (single trigger, e.g. "Perform Duplicate Check") */
  .vob-checkbox {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 14px; color: #374151;
  }

  /* Bottom nav */
  .vob-footer {
    display: flex; justify-content: space-between; align-items: center;
    margin-top: 20px; padding-top: 16px; border-top: 1px solid #e5e7eb;
  }
  .vob-footer .right { display: flex; gap: 8px; }
  .btn {
    padding: 8px 16px; font-size: 14px; font-weight: 500;
    border-radius: 6px; border: none; cursor: pointer;
  }
  .btn-default { background: #fff; border: 1px solid #d1d5db; color: #374151; }
  .btn-default:hover { background: #f9fafb; }
  .btn-primary { background: #1e3a8a; color: #fff; }
  .btn-primary:hover { background: #1e40af; }
  .btn-ghost { background: transparent; color: #374151; }

  .vob-pane { display: none; }
  .vob-pane.active { display: block; }

  /* Duplicate-check results table */
  .dup-table {
    width: 100%; border-collapse: collapse; font-size: 13px;
    margin-top: 4px; border: 1px solid #e5e7eb; border-radius: 6px;
    overflow: hidden;
  }
  .dup-table th, .dup-table td {
    padding: 8px 10px; text-align: left;
    border-bottom: 1px solid #e5e7eb;
    vertical-align: top;
  }
  .dup-table th {
    background: #f9fafb; font-weight: 600; color: #374151; font-size: 12px;
    text-transform: uppercase; letter-spacing: .04em;
  }
  .dup-table tr:last-child td { border-bottom: none; }
  .dup-table tr.hit-high { background: #fef2f2; }
  .dup-table tr.hit-med  { background: #fff7ed; }
  .dup-table .empty { color: #9ca3af; text-align: center; padding: 18px; }
  .dup-flag {
    display: inline-block; font-size: 10px; padding: 2px 7px;
    border-radius: 9999px; background: #dc2626; color: #fff; font-weight: 700;
    margin-right: 4px; letter-spacing: .03em;
  }

  /* Online validation result cards */
  .ov-card {
    border: 1px solid #e5e7eb; border-radius: 8px;
    padding: 10px 14px; background: #fff;
  }
  .ov-head {
    display: flex; align-items: center; gap: 10px;
  }
  .ov-icon {
    width: 26px; height: 26px; border-radius: 4px;
    background: #e5e7eb; color: #374151;
    display: inline-flex; align-items: center; justify-content: center;
    font-weight: 700; font-size: 12px;
  }
  .ov-label { font-weight: 600; color: #111827; }
  .ov-chip {
    margin-left: auto; font-size: 10px; padding: 2px 8px;
    border-radius: 9999px; font-weight: 700; letter-spacing: .04em;
    text-transform: uppercase;
  }
  .ov-match      { background: #dcfce7; color: #065f46; }
  .ov-mismatch   { background: #fef3c7; color: #92400e; }
  .ov-not_found  { background: #e5e7eb; color: #4b5563; }
  .ov-summary    { margin-top: 6px; font-size: 13px; color: #374151; line-height: 1.45; }
  .ov-suggestions {
    margin: 6px 0 0 16px; padding: 0; font-size: 12px; color: #4b5563;
    list-style: disc;
  }
  .ov-suggestions li { margin: 2px 0; }
</style>

<main class="mx-auto max-w-7xl px-4 py-6">
  <div class="mb-4">
    <h1 class="text-2xl font-semibold text-gray-900">Vendor Onboarding Request</h1>
    <p class="text-sm text-gray-500 mt-1">
      Complete all required sections. You can save progress at any time.
    </p>
  </div>

  <div class="vob-shell">
    <!-- ==================== Folder tabs ==================== -->
    <nav class="vob-nav">
      <button type="button" class="vob-tab-btn active" data-tab="docs"><span class="num">1</span><span class="vob-label">Document Upload</span><span class="vob-count"></span></button>
      <button type="button" class="vob-tab-btn"        data-tab="requestor"><span class="num">2</span><span class="vob-label">Requestor Information</span><span class="vob-count"></span></button>
      <button type="button" class="vob-tab-btn"        data-tab="general"><span class="num">3</span><span class="vob-label">General Information</span><span class="vob-count"></span></button>
      <button type="button" class="vob-tab-btn"        data-tab="additional"><span class="num">4</span><span class="vob-label">Additional Details</span><span class="vob-count"></span></button>
      <button type="button" class="vob-tab-btn"        data-tab="compliance"><span class="num">5</span><span class="vob-label">Compliance Questions</span><span class="vob-count"></span></button>
    </nav>

    <!-- ==================== Main form ==================== -->
    <form id="vob-form" method="post" action="/vendors/new/onboarding"
          enctype="multipart/form-data">

      <!-- ============================================= 1) Document Upload -->
      <section class="vob-pane active" data-pane="docs">
        <div class="vob-card">
          <h2>Document Upload</h2>
          <p class="text-sm text-gray-500 mb-3">
            Drop a supplier document (tax form, W-9, business license, etc.) —
            Claude will read it and pre-fill fields in the tabs below.
          </p>
          <%- include('../partials/doc_upload', {
            docDomain: 'VENDOR_ONBOARDING',
            docTitle: 'Document Upload — Vendor Onboarding'
          }) %>
        </div>
      </section>

      <!-- ============================================= 2) General Information -->
      <section class="vob-pane" data-pane="general">
        <div class="vob-card">
          <h2>General Information</h2>
          <div class="indicates-required">* Indicates required</div>

          <div class="section-title">Supplier identity</div>
          <div class="vob-grid">
            <div class="vob-field">
              <label><span class="req">*</span>Supplier Legal Name</label>
              <input type="text" name="legal_name" required>
            </div>
            <div class="vob-field">
              <label>Secondary / Alpha Name</label>
              <input type="text" name="secondary_alpha_name">
            </div>
          </div>

          <div class="section-title">Address</div>
          <div class="vob-grid">
            <div class="vob-field full">
              <label><span class="req">*</span>Address Line 1</label>
              <input type="text" name="addr_line1" required>
            </div>
            <div class="vob-field"><label>Address Line 2</label><input type="text" name="addr_line2"></div>
            <div class="vob-field"><label>Address Line 3</label><input type="text" name="addr_line3"></div>
            <div class="vob-field full"><label>Address Line 4</label><input type="text" name="addr_line4"></div>
            <div class="vob-field">
              <label><span class="req">*</span>City</label>
              <input type="text" name="addr_city" required>
            </div>
            <div class="vob-field">
              <label><span class="req">*</span>ZIP Code</label>
              <input type="text" name="addr_zip" required>
            </div>
            <div class="vob-field">
              <label><span class="req">*</span>Country</label>
              <select name="addr_country" required data-country-name>
                <option value="">-- Select --</option>
                <% lookups.COUNTRIES_FULL.forEach(function (c) { %>
                  <option value="<%= c.name %>"><%= c.flag %>  <%= c.name %></option>
                <% }) %>
              </select>
            </div>
            <div class="vob-field">
              <label><span class="req">*</span>State Code</label>
              <select name="addr_state" required data-state-for="addr_country">
                <option value="">-- Select country first --</option>
              </select>
              <script id="country-states-data" type="application/json"><%- JSON.stringify(lookups.COUNTRY_STATES) %></script>
              <script>
              (function () {
                var states = JSON.parse(document.getElementById('country-states-data').textContent || '{}');
                var countrySel = document.querySelector('[data-country-name]');
                var stateSel   = document.querySelector('[data-state-for="addr_country"]');
                if (!countrySel || !stateSel) return;
                function fill(sel, opts, placeholder) {
                  sel.innerHTML =
                    '<option value="">' + placeholder + '</option>' +
                    opts.map(function (o) { return '<option>' + o.replace(/&/g,'&amp;').replace(/</g,'&lt;') + '</option>'; }).join('');
                }
                function refresh() {
                  var country = countrySel.value;
                  var list = states[country] || [];
                  if (list.length) {
                    fill(stateSel, list, '-- Select state / region --');
                  } else {
                    fill(stateSel, [], country ? '(No subdivisions for this country)' : '-- Select country first --');
                  }
                }
                countrySel.addEventListener('change', refresh);
                if (countrySel.value) refresh();
              })();
              </script>
            </div>
          </div>

          <div class="section-title">Primary contact</div>
          <div class="vob-grid">
            <div class="vob-field">
              <label><span class="req">*</span>Supplier Primary Contact Name</label>
              <input type="text" name="primary_contact_name" required>
            </div>
            <div class="vob-field">
              <label><span class="req">*</span>Supplier Contact Email</label>
              <input type="email" name="primary_contact_email" required>
            </div>
            <div class="vob-field">
              <label><span class="req">*</span>Supplier Contact Phone Area Code</label>
              <select name="primary_contact_phone_area" required data-phone-area>
                <option value="">-- Select country --</option>
                <% lookups.PHONE_CODES.forEach(function (c) { %>
                  <option value="<%= c.dial %>" data-iso2="<%= c.iso2 %>" data-country="<%= c.name %>"><%= c.flag %>  <%= c.name %>  <%= c.dial %></option>
                <% }) %>
              </select>
            </div>
            <div class="vob-field">
              <label><span class="req">*</span>Supplier Contact Phone</label>
              <input type="tel" name="primary_contact_phone" required data-phone-number>
              <div id="phone-error" class="text-xs mt-1" style="min-height:1em;"></div>
            </div>
          </div>

          <!-- Auto-fill area code from selected country, validate phone with libphonenumber. -->
          <script src="https://cdn.jsdelivr.net/npm/libphonenumber-js@1.10.55/bundle/libphonenumber-min.js"></script>
          <script id="phone-codes-by-country" type="application/json"><%- JSON.stringify(lookups.PHONE_CODES.reduce(function (m, c) { m[c.name] = { iso2: c.iso2, dial: c.dial }; return m; }, {})) %></script>
          <script>
          (function () {
            var PHONE_BY_COUNTRY = JSON.parse(document.getElementById('phone-codes-by-country').textContent || '{}');
            var countrySel  = document.querySelector('[data-country-name]');
            var areaSel     = document.querySelector('[data-phone-area]');
            var phoneInput  = document.querySelector('[data-phone-number]');
            var errorEl     = document.getElementById('phone-error');
            if (!countrySel || !areaSel || !phoneInput || !errorEl) return;

            function setError(msg) {
              if (msg) {
                errorEl.textContent = msg;
                errorEl.style.color = '#b91c1c';
                phoneInput.style.borderColor = '#fca5a5';
              } else {
                errorEl.textContent = '';
                phoneInput.style.borderColor = '';
              }
            }

            // Match the selected option in the phone-area select by ISO2 (so
            // multiple countries that share a dial code, e.g. +1, resolve to
            // the right one). Setting select.value would just pick the first
            // <option> with that value — not what we want here. Toggling the
            // matched option's `.selected` property selects it specifically.
            function selectAreaForIso2(iso2) {
              if (!iso2) { areaSel.selectedIndex = 0; return; }
              var opt = areaSel.querySelector('option[data-iso2="' + iso2 + '"]');
              if (opt) {
                opt.selected = true;
                areaSel.dispatchEvent(new Event('change', { bubbles: true }));
              }
            }

            // Auto-populate area code when the user picks a country.
            countrySel.addEventListener('change', function () {
              var rec = PHONE_BY_COUNTRY[countrySel.value];
              if (rec) selectAreaForIso2(rec.iso2);
              validate();
            });

            function selectedIso2() {
              var opt = areaSel.options[areaSel.selectedIndex];
              return opt ? opt.dataset.iso2 || '' : '';
            }

            function validate() {
              var iso2 = selectedIso2();
              var raw  = phoneInput.value.trim();
              if (!raw) { setError(''); return; }
              if (!iso2) { setError('Pick a country / area code first.'); return; }
              if (!window.libphonenumber) { setError(''); return; }   // CDN failed → silent
              try {
                var reason = window.libphonenumber.validatePhoneNumberLength(raw, iso2);
                if (reason === 'TOO_SHORT')      return setError('Phone number is too short for ' + iso2 + '. Check the digit count.');
                if (reason === 'TOO_LONG')       return setError('Phone number is too long for ' + iso2 + '.');
                if (reason === 'INVALID_LENGTH') return setError('Phone number length is not valid for ' + iso2 + '.');
                if (reason === 'INVALID_COUNTRY')return setError('Country code is not recognised.');
                if (reason)                      return setError('Invalid phone number (' + reason + ').');
                if (!window.libphonenumber.isValidPhoneNumber(raw, iso2)) {
                  return setError('Phone number format does not match the expected pattern for ' + iso2 + '.');
                }
                setError('');
              } catch (e) {
                setError('');
              }
            }
            phoneInput.addEventListener('input',  validate);
            areaSel.addEventListener('change',    validate);
          })();
          </script>

          <div class="section-title">Online Validation</div>
          <p class="text-sm text-gray-500 mb-2">
            Cross-check Name, Address and Contact against public sources via Claude.
          </p>
          <div style="display:flex;align-items:center;gap:12px;margin-bottom:12px;">
            <button type="button" id="online-validate-btn" class="btn btn-default">Run online validation</button>
            <span id="online-validate-status" style="font-size:12px;color:#6b7280;"></span>
          </div>
          <div id="online-validate-results" class="space-y-2"></div>

          <div class="section-title">Vendor Category</div>
          <div class="vob-grid">
            <div class="vob-field">
              <label><span class="req">*</span>Category Level 1</label>
              <select name="category_l1" required data-cat-level="1">
                <option value="">-- Select --</option>
                <% Object.keys(lookups.TAXONOMY).sort().forEach(function (l1) { %>
                  <option><%= l1 %></option>
                <% }) %>
              </select>
            </div>
            <div class="vob-field">
              <label><span class="req">*</span>Category Level 2</label>
              <select name="category_l2" required data-cat-level="2"><option value="">-- Select --</option></select>
            </div>
            <div class="vob-field">
              <label><span class="req">*</span>Category Level 3</label>
              <select name="category_l3" required data-cat-level="3"><option value="">-- Select --</option></select>
            </div>
            <div class="vob-field">
              <label><span class="req">*</span>Category Level 4</label>
              <select name="category_l4" required data-cat-level="4"><option value="">-- Select --</option></select>
            </div>
            <script id="taxonomy-data" type="application/json"><%- JSON.stringify(lookups.TAXONOMY) %></script>
            <script>
            (function () {
              var data = JSON.parse(document.getElementById('taxonomy-data').textContent || '{}');
              var l1 = document.querySelector('[data-cat-level="1"]');
              var l2 = document.querySelector('[data-cat-level="2"]');
              var l3 = document.querySelector('[data-cat-level="3"]');
              var l4 = document.querySelector('[data-cat-level="4"]');
              if (!l1 || !l2 || !l3 || !l4) return;
              function fill(sel, opts) {
                sel.innerHTML = '<option value="">-- Select --</option>' +
                  opts.map(function (o) { return '<option>' + o.replace(/&/g,'&amp;').replace(/</g,'&lt;') + '</option>'; }).join('');
              }
              function refresh2() {
                var node = data[l1.value] || {};
                fill(l2, Object.keys(node).sort());
                refresh3();
              }
              function refresh3() {
                var node = ((data[l1.value] || {})[l2.value]) || {};
                fill(l3, Object.keys(node).sort());
                refresh4();
              }
              function refresh4() {
                var node = (((data[l1.value] || {})[l2.value]) || {})[l3.value] || [];
                fill(l4, node);
              }
              l1.addEventListener('change', refresh2);
              l2.addEventListener('change', refresh3);
              l3.addEventListener('change', refresh4);
            })();
            </script>
            <div class="vob-field" data-readonly>
              <label>Commodity Code</label>
              <input type="text" name="commodity_code" readonly>
            </div>
            <div class="vob-field">
              <label>Supplier Nature</label>
              <select name="supplier_nature">
                <option value="">-- Select --</option>
                <% (lookups.madeUp('supplier_attribute') || []).forEach(function (o) { %><option><%= o %></option><% }) %>
              </select>
            </div>
          </div>

          <div class="section-title">Supplier Identifiers</div>
          <div class="vob-grid">
            <div class="vob-field">
              <label><span id="tax-id-label">Tax ID / EIN</span></label>
              <input type="text" name="tax_id" data-tax-id placeholder="XX-XXXXXXX">
              <div id="tax-id-error" style="font-size:12px;margin-top:4px;color:#6b7280;"></div>
            </div>
            <div class="vob-field">
              <label>DUNS #</label>
