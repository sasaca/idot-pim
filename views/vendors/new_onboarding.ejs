<script>
(function () {
  var TABS = ['docs','requestor','general','additional','compliance'];
  var current = 0;

  function show(idx) {
    current = Math.max(0, Math.min(TABS.length - 1, idx));
    document.querySelectorAll('.vob-pane').forEach(function (p) {
      p.classList.toggle('active', p.dataset.pane === TABS[current]);
    });
    document.querySelectorAll('.vob-tab-btn').forEach(function (b) {
      b.classList.toggle('active', b.dataset.tab === TABS[current]);
    });
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  document.querySelectorAll('.vob-tab-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      show(TABS.indexOf(btn.dataset.tab));
    });
  });
  document.getElementById('vob-prev').addEventListener('click', function () { show(current - 1); });
  document.getElementById('vob-next').addEventListener('click', function () { show(current + 1); });

  // Auto-jump to a tab when the URL has #tabname.
  if (window.location.hash) {
    var h = window.location.hash.slice(1);
    var i = TABS.indexOf(h);
    if (i >= 0) show(i);
  }

  // --- Per-tab completion tracker -----------------------------------------
  // Counts required inputs inside each pane, shows "done/total" on the tab,
  // and marks the tab .done (green) only when every required field is filled.
  // Radios/checkboxes sharing a name count as one group.
  function updateCompletion() {
    TABS.forEach(function (key) {
      var pane = document.querySelector('.vob-pane[data-pane="' + key + '"]');
      var btn  = document.querySelector('.vob-tab-btn[data-tab="' + key + '"]');
      if (!pane || !btn) return;
      var countEl = btn.querySelector('.vob-count');

      var required = Array.prototype.slice.call(pane.querySelectorAll('[required]'));
      var nameGroups = {};
      var nonGroup = [];
      required.forEach(function (el) {
        if ((el.type === 'radio' || el.type === 'checkbox') && el.name) {
          (nameGroups[el.name] = nameGroups[el.name] || []).push(el);
        } else {
          nonGroup.push(el);
        }
      });

      var total = nonGroup.length + Object.keys(nameGroups).length;
      var done  = 0;

      nonGroup.forEach(function (el) {
        var v = (el.value != null ? String(el.value) : '').trim();
        if (v !== '') done++;
      });
      Object.keys(nameGroups).forEach(function (name) {
        // Only one radio in a group carries the `required` attribute, so
        // checking the cached list misses the case where the user picks a
        // sibling option (e.g. "No"). Re-query the whole pane by name.
        var siblings = pane.querySelectorAll('[name="' + name.replace(/"/g, '\\"') + '"]');
        for (var i = 0; i < siblings.length; i++) {
          if (siblings[i].checked) { done++; break; }
        }
      });

      if (total === 0) {
        if (countEl) { countEl.style.display = 'none'; countEl.textContent = ''; }
        btn.classList.remove('done');
      } else {
        if (countEl) { countEl.style.display = ''; countEl.textContent = done + '/' + total; }
        btn.classList.toggle('done', done === total);
      }
    });
  }

  var form = document.getElementById('vob-form');
  form.addEventListener('input',  updateCompletion);
  form.addEventListener('change', updateCompletion);
  updateCompletion();

  // --- ERP duplicate check -------------------------------------------------
  function escHtml(s) {
    return String(s == null ? '' : s).replace(/[<>&"']/g, function (c) {
      return { '<':'&lt;', '>':'&gt;', '&':'&amp;', '"':'&quot;', "'":'&#39;' }[c];
    });
  }
  // --- Online validation (Claude + web search) -----------------------------
  var ovBtn = document.getElementById('online-validate-btn');
  if (ovBtn) {
    ovBtn.addEventListener('click', async function () {
      var statusEl  = document.getElementById('online-validate-status');
      var resultsEl = document.getElementById('online-validate-results');
      var payload = {
        legal_name:      (form.elements.legal_name || {}).value || '',
        address_line1:   (form.elements.addr_line1 || {}).value || '',
        address_city:    (form.elements.addr_city  || {}).value || '',
        address_state:   (form.elements.addr_state || {}).value || '',
        address_zip:     (form.elements.addr_zip   || {}).value || '',
        address_country: (form.elements.addr_country || {}).value || '',
        contact_name:    (form.elements.primary_contact_name  || {}).value || '',
        contact_email:   (form.elements.primary_contact_email || {}).value || '',
        contact_phone:   (form.elements.primary_contact_phone || {}).value || '',
      };
      statusEl.textContent = 'Checking public sources…';
      resultsEl.innerHTML = '';
      ovBtn.disabled = true;
      try {
        var res = await fetch('/vendors/api/online-validate', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify(payload),
        });
        var data = await res.json();
        if (!res.ok || !data.result) {
          throw new Error(data.error || data.message || ('HTTP ' + res.status));
        }
        renderOv(data.result);
        statusEl.textContent = 'Validation complete.';
      } catch (err) {
        statusEl.textContent = '';
        resultsEl.innerHTML =
          '<div class="ov-card"><div class="ov-head">' +
            '<span class="ov-icon">!</span><span class="ov-label">Validation failed</span>' +
          '</div><div class="ov-summary">' + escHtml(err.message) + '</div></div>';
      } finally {
        ovBtn.disabled = false;
      }
    });
  }
  function renderOv(r) {
    var resultsEl = document.getElementById('online-validate-results');
    var rows = [
      { key: 'name',    icon: 'N',  label: 'Name',    data: r.name },
      { key: 'address', icon: 'A',  label: 'Address', data: r.address },
      { key: 'contact', icon: '@',  label: 'Contact', data: r.contact },
    ];
    var labels = { match: 'Match', mismatch: 'Mismatch', not_found: 'Not found' };
    resultsEl.innerHTML = rows.map(function (row) {
      var d = row.data || {};
      var status = ['match', 'mismatch', 'not_found'].indexOf(d.status) >= 0 ? d.status : 'not_found';
      var summary = d.summary || '';
      var sugg = (d.suggestions || []).filter(Boolean);
      var suggestionsHtml = (status === 'mismatch' && sugg.length)
        ? '<ul class="ov-suggestions">' + sugg.map(function (x) { return '<li>' + escHtml(x) + '</li>'; }).join('') + '</ul>'
        : '';
      return '<div class="ov-card">' +
          '<div class="ov-head">' +
            '<span class="ov-icon">' + escHtml(row.icon) + '</span>' +
            '<span class="ov-label">' + escHtml(row.label) + '</span>' +
            '<span class="ov-chip ov-' + status + '">' + escHtml(labels[status]) + '</span>' +
          '</div>' +
          (summary ? '<div class="ov-summary">' + escHtml(summary) + '</div>' : '') +
          suggestionsHtml +
        '</div>';
    }).join('');
  }

  var dupBtn = document.getElementById('erp-dup-check-btn');
  if (dupBtn) {
    dupBtn.addEventListener('click', async function () {
      var statusEl = document.getElementById('erp-dup-check-status');
      var tbody    = document.getElementById('erp-dup-results');
      var payload = {
        legal_name:   (form.elements.legal_name   || {}).value || '',
        tax_id:       (form.elements.tax_id       || {}).value || '',
        duns:         (form.elements.duns         || {}).value || '',
        erp_instance: (form.elements.erp_instance || {}).value || '',
        addr_line1:   (form.elements.addr_line1   || {}).value || '',
        addr_city:    (form.elements.addr_city    || {}).value || '',
        addr_state:   (form.elements.addr_state   || {}).value || '',
        addr_zip:     (form.elements.addr_zip     || {}).value || '',
        addr_country: (form.elements.addr_country || {}).value || '',
      };
      statusEl.textContent = 'Checking…';
      tbody.innerHTML = '<tr><td colspan="7" class="empty">Checking…</td></tr>';
      try {
        var res  = await fetch('/vendors/api/erp-dup-check', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify(payload),
        });
        var data = await res.json();
        var matches = (data && data.matches) || [];
        if (!matches.length) {
          tbody.innerHTML = '<tr><td colspan="7" class="empty">No similar suppliers found.</td></tr>';
          statusEl.textContent = 'No matches.';
          return;
        }
        tbody.innerHTML = matches.map(function (m) {
          var rowCls = m.score >= 90 ? 'hit-high' : m.score >= 70 ? 'hit-med' : '';
          var flags  = (m.flags || []).map(function (f) {
            return '<span class="dup-flag">' + escHtml(f) + '</span>';
          }).join('');
          return '<tr class="' + rowCls + '">' +
            '<td>' + escHtml(m.legal_name) + '</td>' +
            '<td>' + escHtml(m.address) + '</td>' +
            '<td>' + escHtml(m.tax_id) + '</td>' +
            '<td>' + escHtml(m.duns) + '</td>' +
            '<td>' + escHtml(m.erp_instance) + '</td>' +
            '<td><strong>' + m.score + '%</strong></td>' +
            '<td>' + flags + '</td>' +
          '</tr>';
        }).join('');
        statusEl.textContent = 'Found ' + matches.length + ' potential match' +
          (matches.length === 1 ? '' : 'es') + '.';
      } catch (e) {
        tbody.innerHTML = '<tr><td colspan="7" class="empty">Error: ' +
          escHtml(e && e.message ? e.message : String(e)) + '</td></tr>';
        statusEl.textContent = 'Error.';
      }
    });
  }
})();
</script>

</div>
</body></html>
