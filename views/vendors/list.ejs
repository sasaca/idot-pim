<%- include('../partials/head', { pageTitle: 'Vendors' }) %>
<%- include('../partials/nav') %>
<div class="main-content">
<%- include('../partials/topbar', { topTitle: 'Vendor Master', topSub: 'All active and inactive vendor records' }) %>
<main class="p-6">

<div class="flex items-start gap-2 mb-4 flex-wrap">
  <form method="get" class="flex gap-2 flex-1">
    <input name="q" placeholder="Search legal name, tax ID, DUNS, ERP supplier ID…" value="<%= typeof query!=='undefined' && query.q || '' %>" class="input max-w-md">
    <select name="status" class="input max-w-[160px]">
      <option value="">All statuses</option>
      <% ['ACTIVE','INACTIVE','BLOCKED','ONE_TIME','PENDING'].forEach(s => { %>
        <option value="<%= s %>" <%= typeof query!=='undefined' && query.status===s ? 'selected':'' %>><%= s %></option>
      <% }) %>
    </select>
    <button class="btn btn-primary">Search</button>
  </form>
  <div class="flex gap-2">
    <a href="/vendors/new/onboarding" class="btn btn-primary">+ Onboard Vendor</a>
    <a href="/vendors/new/one-time" class="btn btn-secondary">+ One-Time</a>
    <% if (currentUser && currentUser.role === 'MASTER_ADMIN') { %>
      <a href="/admin/vendor-workflow" class="btn btn-ghost" title="Configure onboarding stages and triggers">⚙ Workflow</a>
    <% } %>
  </div>
</div>

<div class="card">
  <div class="overflow-x-auto">
    <table class="data">
      <thead><tr>
        <th>Legal name</th><th>ERP ID</th><th>Tax ID</th><th>DUNS</th>
        <th>Category</th><th>Commodity</th><th>Status</th><th>Risk</th><th></th>
      </tr></thead>
      <tbody>
        <% if (!vendors.length) { %>
          <tr><td colspan="9" class="text-center text-slate-500 p-10">No vendors found. <a href="/vendors/new/onboarding" class="text-brand-600 hover:underline">Onboard one →</a></td></tr>
        <% } %>
        <% vendors.forEach(v => { %>
          <tr>
            <td class="font-medium"><%= v.legal_name %></td>
            <td class="font-mono text-xs"><%= v.erp_supplier_id || '—' %></td>
            <td class="text-xs"><%= v.tax_id || '—' %></td>
            <td class="text-xs"><%= v.duns || '—' %></td>
            <td class="text-xs text-slate-600"><%= v.category_l1 || '—' %></td>
            <td class="text-xs text-slate-600"><%= v.commodity_code || '—' %></td>
            <td><span class="chip <%= v.status==='ACTIVE' ? 'bg-emerald-100 text-emerald-700' : v.status==='BLOCKED' ? 'bg-red-100 text-red-700' : 'bg-slate-100 text-slate-700' %>"><%= v.status %></span></td>
            <td><span class="chip <%= v.risk_level==='HIGH' ? 'bg-red-100 text-red-700' : v.risk_level==='MEDIUM' ? 'bg-amber-100 text-amber-700' : 'bg-emerald-100 text-emerald-700' %>"><%= v.risk_level || 'LOW' %></span></td>
            <td><a href="/vendors/<%= v.id %>" class="text-brand-600 hover:underline text-sm">Open →</a></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

</main></div>
</body></html>
