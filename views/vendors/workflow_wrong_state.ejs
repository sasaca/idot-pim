<%- include('../partials/header', { title: 'Wrong stage' }) %>
<main class="mx-auto max-w-2xl px-4 py-16 text-center">
  <h1 class="text-2xl font-semibold text-gray-900">This page isn't available right now</h1>
  <p class="mt-2 text-gray-600">
    Vendor <strong>#<%= vendor.id %></strong> is currently at stage
    <code class="rounded bg-gray-100 px-1 py-0.5 text-sm"><%= current %></code>,
    but this page expected it to be at
    <code class="rounded bg-gray-100 px-1 py-0.5 text-sm"><%= (required || []).join(' or ') %></code>.
  </p>
  <a href="/vendors/queue" class="mt-6 inline-block rounded bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">
    Back to my queue
  </a>
</main>
<%- include('../partials/footer') %>
