<%
/*
  workflow_queue.ejs
  -----------------------------------------------------------------------------
  Role-based "what's waiting for me" queue. Rendered by makeQueueRouter().
  -----------------------------------------------------------------------------
*/
%>
<%- include('../partials/head', { pageTitle: 'My Queue' }) %>
<%- include('../partials/nav') %>
<div class="main-content">
<%- include('../partials/topbar', { topTitle: 'My Queue' }) %>

<main class="mx-auto max-w-5xl px-4 py-8">
  <h1 class="text-2xl font-semibold text-gray-900">My queue</h1>
  <p class="mt-1 text-sm text-gray-500">
    Roles: <%= (roles || []).join(', ') || 'none' %>
  </p>

  <% if (!vendors || vendors.length === 0) { %>
    <div class="mt-8 rounded-lg border border-gray-200 bg-white p-8 text-center text-sm text-gray-500">
      Nothing is waiting on you right now.
    </div>
  <% } else { %>
    <div class="mt-6 overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
      <table class="min-w-full divide-y divide-gray-200 text-sm">
        <thead class="bg-gray-50 text-xs uppercase text-gray-500">
          <tr>
            <th class="px-4 py-3 text-left">ID</th>
            <th class="px-4 py-3 text-left">Legal name</th>
            <th class="px-4 py-3 text-left">Stage</th>
            <th class="px-4 py-3 text-left">Updated</th>
            <th class="px-4 py-3 text-right">Action</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% vendors.forEach(function (v) { %>
            <tr class="hover:bg-gray-50">
              <td class="px-4 py-3 font-mono text-xs text-gray-600"><%= v.id %></td>
              <td class="px-4 py-3 text-gray-900"><%= v.legal_name || '(no name)' %></td>
              <td class="px-4 py-3 text-gray-600"><%= stateLabel(v.workflow_state) %></td>
              <td class="px-4 py-3 text-xs text-gray-500"><%= v.workflow_updated_at || '—' %></td>
              <td class="px-4 py-3 text-right">
                <%
                  var path = {
                    PENDING_SC_REVIEW:    '/vendors/' + v.id + '/workflow/supply-chain-review',
                    PENDING_SUPPLIER:     '/vendors/' + v.id + '/workflow/supplier',
                    PENDING_VENDOR_ADMIN: '/vendors/' + v.id + '/workflow/vendor-admin',
                    PENDING_LEGAL:        '/vendors/' + v.id + '/workflow/legal',
                    NEEDS_INFO:           '/vendors/' + v.id + '/edit',
                    DRAFT:                '/vendors/' + v.id + '/edit',
                  }[v.workflow_state] || ('/vendors/' + v.id);
                %>
                <a href="<%= path %>" class="rounded bg-blue-600 px-3 py-1.5 text-xs font-medium text-white hover:bg-blue-700">
                  Open
                </a>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  <% } %>
</main>

</div>
</body></html>
