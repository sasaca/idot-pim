# Copy this file to `.env` and fill in real values.
# `npm start` loads it automatically (see package.json — Node's --env-file-if-exists).
# Never commit the populated .env.

# Anthropic Messages API (used by lib/claude.js — chat widget + document upload).
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Mapbox Geocoding API (used by routes/address.js — address autocomplete).
# Get a public token at https://account.mapbox.com/access-tokens
MAPBOX_TOKEN=

# Optional — session cookie secret. If unset, server falls back to a dev default.
# SESSION_SECRET=change-me-to-a-long-random-string

# ----- Production-only (set these on Render, not locally) --------------------
# NODE_ENV=production
# Absolute paths inside the host's persistent disk:
# DB_PATH=/var/data/idot.sqlite
# UPLOAD_DIR=/var/data/uploads
# Gates the entire site behind HTTP Basic Auth. Leave blank to disable.
# BASIC_AUTH_USER=
# BASIC_AUTH_PASS=
